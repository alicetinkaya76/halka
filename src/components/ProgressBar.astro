---
// src/components/ProgressBar.astro
//
// Halka v0.14 — İlerleme çubuğu (Ceyhun Hoca öneri #11).
// "Şu an 17. yüzyıl Bilim Devrimi'ndesiniz" benzeri kontekst-anchor.
// BaseLayout header'ının hemen altına ince bant olarak yerleşir.
//
// Hesaplama saf SSR — istemci JS yok.

import { getHalkaProgress } from '@/lib/halka-context';
import { getCollection } from 'astro:content';

const baseUrl = import.meta.env.BASE_URL;
const progress = getHalkaProgress();

// Şu an okunan kitabın era_name'ini frontmatter'dan çek (varsa)
let currentEraName: string | null = null;
if (progress.current) {
  const allBooks = await getCollection('books');
  const currentBook = allBooks.find(
    (b) => b.id.replace(/\.md$/, '') === progress.current!.slug,
  );
  currentEraName = currentBook?.data.period_covered?.era_name ?? null;
}

// Dönem kısa-adı için curriculum'dan çek
const donemShort = progress.currentDonem?.split(' - ')[1] ?? '';
---

<div class="halka-progress" role="status" aria-label={`Halka müfredatında ilerleme: ${progress.percent}%`}>
  <div class="halka-progress-bar-wrapper">
    <div class="halka-progress-bar-track">
      {/* Okundu kısmı — emerald dolu */}
      <div
        class="halka-progress-bar-fill"
        style={`width: ${(progress.okundu / progress.total) * 100}%`}
      ></div>
      {/* Okunuyor kısmı — yarı-saydam */}
      <div
        class="halka-progress-bar-current"
        style={`left: ${(progress.okundu / progress.total) * 100}%; width: ${(progress.okunuyor / progress.total) * 100}%`}
      ></div>
    </div>
  </div>

  <div class="halka-progress-text">
    <span class="halka-progress-counts">
      <strong>{progress.okundu}/{progress.total}</strong>
      <span class="halka-progress-percent">· {progress.percent}%</span>
    </span>
    {progress.current && (
      <span class="halka-progress-current">
        Şu an okunan:{' '}
        <a href={`${baseUrl}/kitaplar/${progress.current.slug}`} class="halka-progress-link">
          {progress.current.author} — {progress.current.title}
        </a>
        {currentEraName && (
          <span class="halka-progress-era">
            <span class="halka-progress-sep">·</span> {donemShort} <span class="halka-progress-sep">·</span>{' '}
            <em>{currentEraName.split(';')[0].split(' (')[0]}</em>
          </span>
        )}
      </span>
    )}
    {!progress.current && (
      <span class="halka-progress-current">
        Şu an okunan kitap yok — sıradaki: 12. kitap (Koyré, 3. Dönem açılışı)
      </span>
    )}
  </div>
</div>

<style>
  .halka-progress {
    border-bottom: 1px solid var(--halka-rule);
    background-color: rgba(247, 245, 240, 0.7);
    backdrop-filter: blur(4px);
    padding: 0.4rem 1.5rem 0.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 0.75rem;
    color: var(--halka-ink);
  }

  .halka-progress-bar-wrapper {
    width: 100%;
  }
  .halka-progress-bar-track {
    position: relative;
    width: 100%;
    height: 4px;
    background-color: var(--halka-rule);
    border-radius: 2px;
    overflow: hidden;
  }
  .halka-progress-bar-fill {
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    background-color: var(--halka-emerald);
    transition: width 400ms ease;
  }
  .halka-progress-bar-current {
    position: absolute;
    top: 0;
    height: 100%;
    background-color: var(--halka-emerald);
    opacity: 0.4;
    animation: progress-pulse 2s ease-in-out infinite;
  }
  @keyframes progress-pulse {
    0%, 100% { opacity: 0.4; }
    50%      { opacity: 0.7; }
  }
  @media (prefers-reduced-motion: reduce) {
    .halka-progress-bar-current { animation: none; }
  }

  .halka-progress-text {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.4rem 0.75rem;
    line-height: 1.4;
  }
  .halka-progress-counts {
    color: var(--halka-emerald);
    font-weight: 500;
  }
  .halka-progress-counts strong {
    font-weight: 700;
  }
  .halka-progress-percent {
    opacity: 0.7;
    font-weight: 400;
  }
  .halka-progress-current {
    color: var(--halka-ink);
    opacity: 0.85;
  }
  .halka-progress-link {
    color: var(--halka-emerald);
    text-decoration: underline;
    text-decoration-color: rgba(14, 107, 94, 0.3);
    text-underline-offset: 2px;
  }
  .halka-progress-link:hover {
    color: var(--halka-emerald-light);
    text-decoration-color: var(--halka-emerald-light);
  }
  .halka-progress-sep {
    color: var(--halka-rule);
    margin: 0 0.1rem;
  }
  .halka-progress-era em {
    font-family: 'Crimson Pro', Georgia, serif;
    font-style: italic;
    font-size: 0.85rem;
  }
</style>
