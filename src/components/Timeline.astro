---
// src/components/Timeline.astro
//
// Halka v0.14 — Kronolojik zaman çizelgesi (Ceyhun Hoca öneri #5).
// "Kafamda hem tarihleri hem olayları oturtmaya çalışıyorum"
// çekirdek ihtiyacının doğrudan adresi.
//
// Tasarım kararları:
// - Custom Astro+SVG (TimelineJS embed reddedildi — marka uyumsuzluğu)
// - Parçalı eksen: -3000…0 sıkıştırılmış, 0…1500 normal, 1500…2026 normal
//   (Halka'nın "Doğu Bilim Geleneği" yoğunluğu öne çıksın diye)
// - İki katman: üstte 11 kitap period_covered.start→end yatay-bant,
//   altta 13 kişi birth_year→death_year çubuğu
// - Bilinmeyen birth_year: ölüm yılından 60-yıl öncesi varsayılır,
//   görsel "?...ölüm" formatında işaretlenir
// - Server-render SVG; istemci JS yok (CSS hover yeterli)

import { getCollection } from 'astro:content';
import { curriculum } from '@/lib/curriculum';
import { DONEM_COLORS, yearToX, TIMELINE_TICKS, parseYear } from '@/lib/halka-context';

const baseUrl = import.meta.env.BASE_URL;

const books = await getCollection('books');
const people = await getCollection('people');

// SVG geometri
const W = 1400;
const PAD_L = 100;             // sol kenar boşluğu (yer bilgisi için)
const PAD_R = 30;
const PLOT_W = W - PAD_L - PAD_R;

const BAND_H = 22;             // her kitap-bant'ı yüksekliği
const BAND_GAP = 4;
const PERSON_BAR_H = 14;
const PERSON_GAP = 3;
const AXIS_H = 50;             // alt eksen yüksekliği

// Veriyi normalize et — kitaplar
const flatBooks = curriculum.flatMap((d) =>
  d.books.map((b) => ({
    ...b,
    donem: d.donem,
    donemColor: DONEM_COLORS[d.donem],
  })),
);
const builtBookData = books.map((b) => {
  const slug = b.id.replace(/\.md$/, '');
  const hp = b.data.historiographical_position;
  return {
    slug,
    start: b.data.period_covered?.start ?? null,
    end: b.data.period_covered?.end ?? null,
    eraName: b.data.period_covered?.era_name ?? '',
    siraNo: b.data.halka_metadata.sira_no,
    // v0.20 — UI-D: tarihçi-yorum-rozetleri için historiographical_position aktarımı
    eurAxis: hp.eurocentrism_axis,
    ieAxis: hp.internalist_externalist,
  };
});
const builtBookMap = new Map(builtBookData.map((b) => [b.slug, b]));

// 11 kitap timeline'a girer (period_covered olan); diğer 10 müfredat-stub'ı atlanır
const timelineBooks = flatBooks
  .filter((b) => builtBookMap.has(b.slug) && builtBookMap.get(b.slug)!.start !== null)
  .map((b) => {
    const built = builtBookMap.get(b.slug)!;
    return {
      ...b,
      start: built.start!,
      end: built.end!,
      eraName: built.eraName,
      // v0.20 — UI-D: tarihyazımı-konum-rozetleri
      eurAxis: built.eurAxis,
      ieAxis: built.ieAxis,
    };
  })
  // Görsel düzen: start yılına göre sırala (en eski → en yeni)
  .sort((a, b) => a.start - b.start);

// v0.20 — UI-D: Tarihyazımı-rozet-renk-paleti
// Eurocentrism rozet-renkleri: anti-Eurocentric=emerald-vurgu (eleştirel-konum),
// Eurocentric=carmine (klasik-merkez), noteurocentric-but-comparative=amber
// (orta-yol), agnostic=ink-warm-gri (yorum-konumlamasız).
const EUR_PALETTE: Record<string, { color: string; label: string }> = {
  'anti-Eurocentric':                 { color: '#0e6b5e', label: 'anti-Eurocentric' },
  'Eurocentric':                      { color: '#9c2a3b', label: 'Eurocentric' },
  'noteurocentric-but-comparative':   { color: '#ba7517', label: 'karşılaştırmalı (Eurocentric değil)' },
  'agnostic':                         { color: '#888780', label: 'agnostik' },
};
// Internalist/externalist rozet-renkleri: internalist=mor (bilim-içi-okuma),
// externalist=koyu-turuncu (toplumsal-bağlam-okuma), mixed=amber (hibrit).
const IE_PALETTE: Record<string, { color: string; label: string }> = {
  'internalist': { color: '#534ab7', label: 'internalist (bilim-içi)' },
  'externalist': { color: '#d85a30', label: 'externalist (toplumsal-bağlam)' },
  'mixed':       { color: '#bb900c', label: 'karma' },
};

// v0.20 — UI-D: Filtre-bar dropdown-seçeneklerinin gerçek-veriden-türetilmesi.
// Yapısal-disiplin: dropdown sadece datada gerçekten geçen ekstem-değerleri
// gösterir; "Eurocentric" filtresi 0 sonuç döndürmesin.
const presentEurValues = Array.from(new Set(timelineBooks.map((b) => b.eurAxis))).sort();
const presentIeValues  = Array.from(new Set(timelineBooks.map((b) => b.ieAxis))).sort();

// Veriyi normalize et — kişiler
const timelinePeople = people
  .map((p) => {
    const slug = p.id.replace(/\.md$/, '');
    const birth = parseYear(p.data.birth_year);
    const death = parseYear(p.data.death_year);
    return {
      slug,
      name: p.data.name,
      birth,
      death,
      // Sadece death_year varsa: birth = death - 60 (yaklaşık ortalama ömür)
      // Ama görsel olarak "?-death" işaretle
      effectiveBirth: birth ?? (death ? death - 60 : null),
      hasUnknownBirth: birth === null && death !== null,
      role: p.data.role ?? '',
      fields: p.data.fields ?? [],
    };
  })
  .filter((p) => p.effectiveBirth !== null && p.death !== null)
  .sort((a, b) => a.effectiveBirth! - b.effectiveBirth!);

// Yükseklik hesapla
const BOOKS_BLOCK_H = timelineBooks.length * (BAND_H + BAND_GAP);
const PEOPLE_BLOCK_H = timelinePeople.length * (PERSON_BAR_H + PERSON_GAP);
const TITLE_H = 30;
const SUBTITLE_H = 20;
const H = TITLE_H + BOOKS_BLOCK_H + 30 + SUBTITLE_H + PEOPLE_BLOCK_H + 20 + AXIS_H;

const BOOKS_Y0 = TITLE_H;
const PEOPLE_Y0 = TITLE_H + BOOKS_BLOCK_H + 30 + SUBTITLE_H;
const AXIS_Y0 = H - AXIS_H + 10;
---

<div class="halka-timeline-wrapper" id="halka-timeline-root">
  <div class="halka-timeline-meta" role="region" aria-label="Timeline lejantı">
    <p class="halka-timeline-meta-title">Atomik Atlas — kronolojik katman</p>
    <p class="halka-timeline-meta-desc">
      <strong>{timelineBooks.length} kitap</strong>'ın kapsadığı dönemler (üst) ve
      atomik atlasta yer alan <strong>{timelinePeople.length} kişi</strong>'nin yaşam
      aralıkları (alt). Eksen parçalıdır: M.Ö. 3000–0 sıkıştırılmış, 0–1500 ve
      1500–2026 normal ölçek (Doğu Bilim Geleneği yoğunluğu görünür kalsın diye).
      Kişi çubuklarındaki <em>?</em> işareti doğum yılı bilinmediği için ölüm
      yılından 60-yıl öncesi varsayıldığını gösterir.
      <br />
      <strong>v0.20 UI-D:</strong> Her kitap-bantın solunda iki minik-rozet,
      kitabın <em>tarihyazımı-konumunu</em> gösterir: <strong>iç-rozet</strong>
      Eurocentrism-aksisi (anti-Eurocentric=emerald, Eurocentric=carmine,
      karşılaştırmalı=amber, agnostik=gri); <strong>dış-rozet</strong>
      internalist/externalist-aksisi (mor=bilim-içi, turuncu=toplumsal-bağlam,
      amber=karma). Aşağıdan filtreleyebilirsiniz.
    </p>
    {/* v0.20 — UI-D: Tarihyazımı-konum-filtresi */}
    <div class="halka-timeline-filter">
      <label class="halka-timeline-filter-label">
        <span>Eurocentrism-aksisi:</span>
        <select id="hp-filter-eur" class="halka-timeline-filter-select">
          <option value="">— tümü —</option>
          {presentEurValues.map((v) => (
            <option value={v}>{EUR_PALETTE[v]?.label ?? v}</option>
          ))}
        </select>
      </label>
      <label class="halka-timeline-filter-label">
        <span>İnternalist/externalist-aksisi:</span>
        <select id="hp-filter-ie" class="halka-timeline-filter-select">
          <option value="">— tümü —</option>
          {presentIeValues.map((v) => (
            <option value={v}>{IE_PALETTE[v]?.label ?? v}</option>
          ))}
        </select>
      </label>
      <button id="hp-filter-reset" class="halka-timeline-filter-reset" type="button">Sıfırla</button>
      <span id="hp-filter-counter" class="halka-timeline-filter-counter" aria-live="polite"></span>
    </div>
  </div>

  <div class="halka-timeline-scroll">
    <svg
      viewBox={`0 0 ${W} ${H}`}
      xmlns="http://www.w3.org/2000/svg"
      class="halka-timeline-svg"
      role="img"
      aria-label="Halka kronolojik atlası"
    >
      {/* Başlık */}
      <text
        x={PAD_L}
        y={20}
        font-family="Inter, system-ui, sans-serif"
        font-size="14"
        font-weight="600"
        fill="var(--halka-emerald)"
      >
        Kitapların kapsadığı dönemler
      </text>

      {/* Tick çizgileri arka plan (kitap bandının altında çizgi) */}
      {TIMELINE_TICKS.map((y) => {
        const x = PAD_L + yearToX(y, PLOT_W);
        return (
          <line
            x1={x}
            y1={BOOKS_Y0}
            x2={x}
            y2={H - AXIS_H + 5}
            stroke="var(--halka-rule)"
            stroke-width="0.5"
            stroke-dasharray="2 3"
            opacity="0.5"
          />
        );
      })}

      {/* Kitap bantları */}
      {timelineBooks.map((b, i) => {
        const x1 = PAD_L + yearToX(b.start, PLOT_W);
        const x2 = PAD_L + yearToX(b.end, PLOT_W);
        const y = BOOKS_Y0 + i * (BAND_H + BAND_GAP);
        const w = Math.max(2, x2 - x1);
        const labelText = `#${b.sira_no} ${b.author.split(' ').pop()}`;
        // v0.20 — UI-D: tarihyazımı-rozet renkleri
        const eurMeta = EUR_PALETTE[b.eurAxis];
        const ieMeta = IE_PALETTE[b.ieAxis];
        const cy = y + BAND_H / 2;
        return (
          <a
            href={`${baseUrl}/kitaplar/${b.slug}`}
            class="halka-timeline-book"
            data-eur={b.eurAxis}
            data-ie={b.ieAxis}
          >
            <title>{`#${b.sira_no} · ${b.title} — ${b.author} · ${b.start} → ${b.end}\nTarihyazımı: ${eurMeta?.label ?? b.eurAxis} · ${ieMeta?.label ?? b.ieAxis}${b.eraName ? '\n' + b.eraName.split(';')[0] : ''}`}</title>
            {/* v0.20 UI-D: Tarihyazımı-konum-rozetleri (sabit-sol-kolon, x=10 ve x=24) */}
            <circle
              cx={10}
              cy={cy}
              r={4}
              fill={eurMeta?.color ?? 'transparent'}
              stroke={eurMeta?.color ?? 'var(--halka-rule)'}
              stroke-width="1"
              opacity={eurMeta ? 0.85 : 0.3}
              class="halka-timeline-rozet halka-timeline-rozet-eur"
            />
            <circle
              cx={24}
              cy={cy}
              r={4}
              fill={ieMeta?.color ?? 'transparent'}
              stroke={ieMeta?.color ?? 'var(--halka-rule)'}
              stroke-width="1"
              opacity={ieMeta ? 0.85 : 0.3}
              class="halka-timeline-rozet halka-timeline-rozet-ie"
            />
            <rect
              x={x1}
              y={y}
              width={w}
              height={BAND_H}
              fill={b.donemColor.fill}
              fill-opacity="0.55"
              stroke={b.donemColor.stroke}
              stroke-width="1"
              rx="2"
            />
            {/* Yıl etiketleri rect'in dışında */}
            <text
              x={x1 - 4}
              y={y + BAND_H / 2 + 4}
              text-anchor="end"
              font-family="JetBrains Mono, monospace"
              font-size="9"
              fill="var(--halka-ink)"
              opacity="0.6"
            >
              {b.start < 0 ? `M.Ö. ${-b.start}` : b.start}
            </text>
            <text
              x={x2 + 4}
              y={y + BAND_H / 2 + 4}
              text-anchor="start"
              font-family="JetBrains Mono, monospace"
              font-size="9"
              fill="var(--halka-ink)"
              opacity="0.6"
            >
              {b.end < 0 ? `M.Ö. ${-b.end}` : b.end}
            </text>
            {/* Bant içi label (yer varsa) */}
            {w > 100 && (
              <text
                x={(x1 + x2) / 2}
                y={y + BAND_H / 2 + 4}
                text-anchor="middle"
                font-family="Inter, system-ui, sans-serif"
                font-size="11"
                font-weight="500"
                fill="var(--halka-ink)"
                style="pointer-events: none;"
              >
                {labelText}
              </text>
            )}
            {/* Kısa bantlarda yan etiket */}
            {w <= 100 && (
              <text
                x={x2 + 30}
                y={y + BAND_H / 2 + 4}
                text-anchor="start"
                font-family="Inter, system-ui, sans-serif"
                font-size="10"
                fill="var(--halka-ink)"
              >
                {labelText}
              </text>
            )}
          </a>
        );
      })}

      {/* Kişiler bölümü başlığı */}
      <text
        x={PAD_L}
        y={PEOPLE_Y0 - 8}
        font-family="Inter, system-ui, sans-serif"
        font-size="14"
        font-weight="600"
        fill="var(--halka-emerald)"
      >
        Atomik atlasta kişiler
      </text>

      {/* Kişi çubukları */}
      {timelinePeople.map((p, i) => {
        const xb = PAD_L + yearToX(p.effectiveBirth!, PLOT_W);
        const xd = PAD_L + yearToX(p.death!, PLOT_W);
        const y = PEOPLE_Y0 + i * (PERSON_BAR_H + PERSON_GAP);
        const w = Math.max(2, xd - xb);
        return (
          <a href={`${baseUrl}/kisiler/${p.slug}`} class="halka-timeline-person">
            <title>{`${p.name} · ${p.hasUnknownBirth ? '?' : p.effectiveBirth} - ${p.death}${p.role ? '\n' + p.role : ''}`}</title>
            <rect
              x={xb}
              y={y}
              width={w}
              height={PERSON_BAR_H}
              fill={p.hasUnknownBirth ? 'transparent' : 'var(--halka-emerald)'}
              fill-opacity={p.hasUnknownBirth ? 0 : 0.6}
              stroke="var(--halka-emerald)"
              stroke-width="1"
              stroke-dasharray={p.hasUnknownBirth ? '3 2' : ''}
              rx="2"
            />
            <text
              x={xb - 4}
              y={y + PERSON_BAR_H / 2 + 3.5}
              text-anchor="end"
              font-family="Inter, system-ui, sans-serif"
              font-size="10"
              fill="var(--halka-ink)"
              opacity="0.85"
            >
              {p.name}
            </text>
            <text
              x={xd + 4}
              y={y + PERSON_BAR_H / 2 + 3.5}
              text-anchor="start"
              font-family="JetBrains Mono, monospace"
              font-size="9"
              fill="var(--halka-ink)"
              opacity="0.6"
            >
              {p.hasUnknownBirth ? '?' : p.effectiveBirth}–{p.death}
            </text>
          </a>
        );
      })}

      {/* Eksen — alt çizgi + tick'ler */}
      <line
        x1={PAD_L}
        y1={AXIS_Y0}
        x2={W - PAD_R}
        y2={AXIS_Y0}
        stroke="var(--halka-ink)"
        stroke-width="1"
      />
      {TIMELINE_TICKS.map((y) => {
        const x = PAD_L + yearToX(y, PLOT_W);
        const label = y === 0 ? '0' : y < 0 ? `M.Ö. ${-y}` : `${y}`;
        return (
          <g>
            <line
              x1={x}
              y1={AXIS_Y0}
              x2={x}
              y2={AXIS_Y0 + 5}
              stroke="var(--halka-ink)"
              stroke-width="1"
            />
            <text
              x={x}
              y={AXIS_Y0 + 18}
              text-anchor="middle"
              font-family="JetBrains Mono, monospace"
              font-size="10"
              fill="var(--halka-ink)"
            >
              {label}
            </text>
          </g>
        );
      })}

      {/* Eksen başlığı */}
      <text
        x={(PAD_L + W - PAD_R) / 2}
        y={AXIS_Y0 + 38}
        text-anchor="middle"
        font-family="Inter, system-ui, sans-serif"
        font-size="11"
        font-weight="500"
        fill="var(--halka-ink)"
        opacity="0.7"
      >
        Yıl ekseni (parçalı: M.Ö. 3000–0 sıkıştırılmış)
      </text>
    </svg>
  </div>
</div>

<style>
  .halka-timeline-wrapper {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .halka-timeline-meta {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 0.85rem;
    padding: 0.75rem 1rem;
    background-color: rgba(255, 255, 255, 0.6);
    border: 1px solid var(--halka-rule);
    border-radius: 2px;
  }
  .halka-timeline-meta-title {
    font-weight: 600;
    color: var(--halka-emerald);
    margin: 0 0 0.4rem;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .halka-timeline-meta-desc {
    margin: 0;
    font-family: 'Crimson Pro', Georgia, serif;
    font-size: 1rem;
    line-height: 1.5;
  }
  .halka-timeline-scroll {
    width: 100%;
    overflow-x: auto;
    border: 1px solid var(--halka-rule);
    border-radius: 2px;
    background-color: white;
  }
  .halka-timeline-svg {
    display: block;
    min-width: 1400px;
    height: auto;
  }

  .halka-timeline-book,
  .halka-timeline-person {
    cursor: pointer;
    transition: opacity 150ms ease;
  }
  .halka-timeline-book:hover rect,
  .halka-timeline-person:hover rect {
    fill-opacity: 0.85;
    stroke-width: 2;
  }

  /* v0.20 — UI-D: Tarihyazımı-rozet hover-vurgusu */
  .halka-timeline-book:hover .halka-timeline-rozet {
    opacity: 1;
    stroke-width: 1.5;
  }

  /* v0.20 — UI-D: Filtre-bar tasarım-sistemine uyumlu */
  .halka-timeline-filter {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.6rem 1.1rem;
    margin-top: 0.85rem;
    padding-top: 0.75rem;
    border-top: 1px dashed var(--halka-rule);
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 0.78rem;
  }
  .halka-timeline-filter-label {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    color: var(--halka-ink);
  }
  .halka-timeline-filter-label > span {
    font-weight: 500;
    letter-spacing: 0.01em;
    color: var(--halka-emerald);
  }
  .halka-timeline-filter-select {
    appearance: none;
    -webkit-appearance: none;
    font-family: inherit;
    font-size: 0.78rem;
    padding: 0.28rem 1.6rem 0.28rem 0.55rem;
    border: 1px solid var(--halka-rule);
    border-radius: 2px;
    background: rgba(255, 255, 255, 0.85);
    background-image: linear-gradient(45deg, transparent 50%, var(--halka-emerald) 50%),
                      linear-gradient(135deg, var(--halka-emerald) 50%, transparent 50%);
    background-position: calc(100% - 14px) center, calc(100% - 9px) center;
    background-size: 5px 5px, 5px 5px;
    background-repeat: no-repeat;
    color: var(--halka-ink);
    cursor: pointer;
    transition: border-color 150ms ease;
  }
  .halka-timeline-filter-select:hover,
  .halka-timeline-filter-select:focus {
    border-color: var(--halka-emerald);
    outline: none;
  }
  .halka-timeline-filter-reset {
    font-family: inherit;
    font-size: 0.75rem;
    padding: 0.25rem 0.65rem;
    border: 1px solid var(--halka-rule);
    border-radius: 2px;
    background: transparent;
    color: var(--halka-ink);
    cursor: pointer;
    letter-spacing: 0.01em;
    transition: border-color 150ms ease, color 150ms ease;
  }
  .halka-timeline-filter-reset:hover {
    border-color: var(--halka-emerald);
    color: var(--halka-emerald);
  }
  .halka-timeline-filter-counter {
    margin-left: auto;
    color: var(--halka-ink);
    opacity: 0.65;
    font-size: 0.72rem;
    font-style: italic;
  }

  /* Filtreyle eşleşmeyen bantlar dim-state. Tıklamayı da pasifleştir
     (pointer-events:none) ki yanlışlıkla saklı-bant tıklanmasın. */
  .halka-timeline-book.is-dim {
    opacity: 0.12;
    pointer-events: none;
  }
</style>

{/* v0.20 — UI-D: Filtre-bar JS (vanilla, 0 bağımlılık).
    JS yüklenmezse her şey normal görünür — graceful-degradation. */}
<script is:inline>
  (function () {
    'use strict';
    function init() {
      var root = document.getElementById('halka-timeline-root');
      if (!root) return;
      var eurSel = document.getElementById('hp-filter-eur');
      var ieSel  = document.getElementById('hp-filter-ie');
      var reset  = document.getElementById('hp-filter-reset');
      var counter = document.getElementById('hp-filter-counter');
      if (!eurSel || !ieSel) return;
      var bands = root.querySelectorAll('.halka-timeline-book');
      var total = bands.length;

      function apply() {
        var eur = eurSel.value;
        var ie  = ieSel.value;
        var visible = 0;
        for (var i = 0; i < bands.length; i++) {
          var el = bands[i];
          var elEur = el.getAttribute('data-eur');
          var elIe  = el.getAttribute('data-ie');
          var match = (!eur || elEur === eur) && (!ie || elIe === ie);
          if (match) {
            el.classList.remove('is-dim');
            visible++;
          } else {
            el.classList.add('is-dim');
          }
        }
        if (counter) {
          if (eur || ie) {
            counter.textContent = visible + ' / ' + total + ' kitap';
          } else {
            counter.textContent = '';
          }
        }
      }

      eurSel.addEventListener('change', apply);
      ieSel.addEventListener('change', apply);
      if (reset) {
        reset.addEventListener('click', function () {
          eurSel.value = '';
          ieSel.value = '';
          apply();
        });
      }
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
</script>
