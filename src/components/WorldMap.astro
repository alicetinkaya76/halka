---
// src/components/WorldMap.astro
//
// Halka v0.14 — Dünya haritası (Ceyhun Hoca öneri #1, #2).
// Leaflet 1.9.x üzerine kurulu. Türkiye-merkezli ama 7 yer atomiği
// etrafında doğal gruplanır (İstanbul'dan Bağdat-Kâhire ekseni
// görünür). Marker büyüklüğü o yere referans veren kitap sayısıyla
// orantılı (Bağdat 7-rekor en büyük, Kâhire 1-küçük).
//
// Marker'a tıklayınca popup açılır → place adı + role özeti +
// "Detaylı sayfaya git →" linki (/yerler/[slug]).
//
// Leaflet CDN'den yüklenir; sadece bu sayfa için harcanır.

import { getCollection } from 'astro:content';
import { countBookReferences, refCountToRadius } from '@/lib/halka-context';

const baseUrl = import.meta.env.BASE_URL;

const places = await getCollection('places');
const books = await getCollection('books');

// Sadece coordinate'i olan yerler haritaya çıkar
const mapPlaces = places
  .filter((p) => p.data.coordinates)
  .map((p) => {
    const slug = p.id.replace(/\.md$/, '');
    const refCount = countBookReferences(slug, books as any);
    return {
      slug,
      name: p.data.name,
      nameModern: p.data.name_modern,
      countryModern: p.data.country_modern,
      lat: p.data.coordinates!.lat,
      lon: p.data.coordinates!.lon,
      role: p.data.role ?? '',
      refCount,
      radius: refCountToRadius(refCount),
    };
  });

const placesJson = JSON.stringify(mapPlaces);
---

<div class="halka-map-wrapper">
  <div id="halka-world-map" class="halka-map"></div>
  <div class="halka-map-meta" role="region" aria-label="Harita lejantı">
    <p class="halka-map-meta-title">Atomik Atlas — coğrafi katman</p>
    <p class="halka-map-meta-desc">
      <strong>{mapPlaces.length} yer-atomiği.</strong> Marker büyüklüğü kitap-referans
      derinliği: Bağdat'ın 7-kitap rekorundan Kâhire'nin 1-kitap atomiğine.
      Marker'a tıklayın — yer detayı popup'ta açılır.
    </p>
    <p class="halka-map-meta-credit">
      Harita döşemeleri: <a href="https://www.openstreetmap.org/copyright" target="_blank" rel="noopener">OpenStreetMap</a> katkıcıları, ODbL · Halka koordinatları Wikidata'dan
    </p>
  </div>
</div>

{/* Leaflet CSS — CDN'den, sadece bu sayfada */}
<link
  rel="stylesheet"
  href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
  integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
  crossorigin=""
/>

{/* Marker dataset — global window'a koymadan, script-içi inline JSON */}
<script type="application/json" id="halka-places-json" set:html={placesJson} is:inline></script>

<script
  is:inline
  src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
  integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
  crossorigin=""
></script>

<script is:inline define:vars={{ baseUrl }}>
  // Leaflet script yüklendiğinde tetiklenir
  function initHalkaMap() {
    if (typeof L === 'undefined') {
      // Leaflet henüz yüklenmemiş — 100ms sonra tekrar dene
      setTimeout(initHalkaMap, 100);
      return;
    }

    const dataEl = document.getElementById('halka-places-json');
    if (!dataEl) return;
    const places = JSON.parse(dataEl.textContent);

    // Türkiye merkezli ama Bağdat-Kâhire ekseni görünür → Anadolu-İran-Levant ortası
    const map = L.map('halka-world-map', {
      center: [36.0, 38.0],
      zoom: 4,
      minZoom: 2,
      maxZoom: 10,
      scrollWheelZoom: false,        // sayfa scroll'unu kırmamak için
    });

    // OpenStreetMap döşemeleri
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OSM</a>',
      maxZoom: 18,
    }).addTo(map);

    // Halka design system renkleri
    const HALKA_EMERALD = '#0e6b5e';
    const HALKA_INK = '#191510';

    // Marker'ları ekle
    for (const p of places) {
      const marker = L.circleMarker([p.lat, p.lon], {
        radius: p.radius,
        color: HALKA_INK,
        weight: 1.5,
        fillColor: HALKA_EMERALD,
        fillOpacity: 0.65,
      }).addTo(map);

      const roleShort = p.role.length > 220 ? p.role.slice(0, 220) + '…' : p.role;
      const popupHtml = `
        <div class="halka-map-popup">
          <h4>${p.name}${p.nameModern && p.nameModern !== p.name ? ` <span style="opacity:0.6;font-weight:400;">(${p.nameModern})</span>` : ''}</h4>
          ${p.countryModern ? `<p class="halka-map-popup-meta">${p.countryModern} · ${p.refCount} kitapta geçer</p>` : ''}
          <p class="halka-map-popup-role">${roleShort}</p>
          <p class="halka-map-popup-link"><a href="${baseUrl}/yerler/${p.slug}">Yer detayı &rarr;</a></p>
        </div>
      `;
      marker.bindPopup(popupHtml, { maxWidth: 360, className: 'halka-popup-container' });

      // Hover: marker'ı vurgula
      marker.on('mouseover', function () { this.setStyle({ fillOpacity: 0.9, weight: 2.5 }); });
      marker.on('mouseout',  function () { this.setStyle({ fillOpacity: 0.65, weight: 1.5 }); });
    }

    // Tüm marker'ları kapsayan bbox'a otomatik fit (ama çok yakın zoomlama olmasın)
    if (places.length > 0) {
      const bounds = L.latLngBounds(places.map((p) => [p.lat, p.lon]));
      map.fitBounds(bounds, { padding: [40, 40], maxZoom: 5 });
    }
  }

  // Astro view-transition uyumlu yükleme
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initHalkaMap);
  } else {
    initHalkaMap();
  }
</script>

<style is:global>
  /* Leaflet popup'a Halka tasarım dili uygulanır */
  .halka-popup-container .leaflet-popup-content-wrapper {
    background-color: var(--halka-paper, #f7f5f0);
    border-radius: 2px;
    border: 1px solid var(--halka-rule, #d6cfbb);
    box-shadow: 0 4px 12px rgba(25, 21, 16, 0.15);
  }
  .halka-popup-container .leaflet-popup-tip {
    background-color: var(--halka-paper, #f7f5f0);
    border: 1px solid var(--halka-rule, #d6cfbb);
  }
  .halka-popup-container .leaflet-popup-content {
    margin: 0.85rem 1rem;
    font-family: 'Crimson Pro', Georgia, serif;
    font-size: 14px;
    line-height: 1.5;
  }
  .halka-map-popup h4 {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 1rem;
    font-weight: 600;
    color: var(--halka-ink);
    margin: 0 0 0.25rem;
  }
  .halka-map-popup-meta {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 0.7rem;
    color: var(--halka-emerald);
    margin: 0 0 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .halka-map-popup-role {
    color: var(--halka-ink);
    margin: 0 0 0.6rem;
    font-size: 0.85rem;
    line-height: 1.45;
  }
  .halka-map-popup-link {
    margin: 0;
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 0.8rem;
  }
  .halka-map-popup-link a {
    color: var(--halka-emerald);
    text-decoration: underline;
    text-decoration-color: rgba(14, 107, 94, 0.4);
    font-weight: 500;
  }
  .halka-map-popup-link a:hover {
    color: var(--halka-emerald-light);
  }
</style>

<style>
  .halka-map-wrapper {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .halka-map {
    height: 540px;
    width: 100%;
    border: 1px solid var(--halka-rule);
    border-radius: 2px;
    background-color: #e9e6dc;       /* loading state */
  }
  .halka-map-meta {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 0.85rem;
    color: var(--halka-ink);
    padding: 0.75rem 1rem;
    background-color: rgba(255, 255, 255, 0.6);
    border: 1px solid var(--halka-rule);
    border-radius: 2px;
  }
  .halka-map-meta-title {
    font-weight: 600;
    color: var(--halka-emerald);
    margin: 0 0 0.4rem;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .halka-map-meta-desc {
    margin: 0 0 0.4rem;
    font-family: 'Crimson Pro', Georgia, serif;
    font-size: 1rem;
    line-height: 1.5;
  }
  .halka-map-meta-credit {
    margin: 0;
    font-size: 0.7rem;
    color: var(--halka-ink);
    opacity: 0.6;
  }
  @media (max-width: 640px) {
    .halka-map { height: 380px; }
  }
</style>
