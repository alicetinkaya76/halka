---
// src/components/InfluenceGraph.astro
//
// Halka v0.14 — Etki ağı (Ceyhun Hoca öneri #6).
// "Kim kimden etkilendi? El-Harezmi'nin cebir çalışmaları Batı'da
// kimin yolunu açtı?" sorusunun graph-visualizasyonu.
//
// Düğümler:
//   - Kitaplar (mavi-yeşil emerald, daha büyük) — referans-derinliğine göre
//   - Kişiler (carmine, küçük) — atomik atlas dosyası olanlar
//
// Kenarlar:
//   - book → book: relationships_to_other_books (relation tipine göre renk)
//   - person → person: influenced_by/influenced
//   - book → person: key_people (kitap içinde geçen kişi — opsiyonel,
//     graph kalabalığını önlemek için varsayılan olarak gizli, toggle ile açılır)
//
// Cytoscape.js CDN'den lazy-load — sadece bu sayfa için yüklenir.

import { getCollection } from 'astro:content';
import { countBookReferences, countPersonReferences } from '@/lib/halka-context';

const baseUrl = import.meta.env.BASE_URL;

const books = await getCollection('books');
const people = await getCollection('people');

// --- Düğümler ---

const bookNodes = books.map((b) => {
  const slug = b.id.replace(/\.md$/, '');
  return {
    data: {
      id: `book:${slug}`,
      slug,
      label: b.data.author.split(' ').pop() ?? b.data.author,
      title: b.data.title,
      author: b.data.author,
      type: 'book',
      siraNo: b.data.halka_metadata.sira_no,
      donem: b.data.halka_metadata.donem,
    },
  };
});

const personNodes = people.map((p) => {
  const slug = p.id.replace(/\.md$/, '');
  const refCount = countPersonReferences(slug, books as any);
  return {
    data: {
      id: `person:${slug}`,
      slug,
      label: p.data.name,
      type: 'person',
      refCount,
      role: p.data.role ?? '',
    },
  };
});

// --- Kenarlar ---

// Kitap → kitap (relationships_to_other_books)
const bookToBookEdges: any[] = [];
for (const b of books) {
  const sourceSlug = b.id.replace(/\.md$/, '');
  for (const rel of b.data.relationships_to_other_books ?? []) {
    bookToBookEdges.push({
      data: {
        id: `e:b2b:${sourceSlug}->${rel.book}:${rel.relation}`,
        source: `book:${sourceSlug}`,
        target: `book:${rel.book}`,
        relation: rel.relation,
        kind: 'book2book',
      },
    });
  }
}

// Kişi → kişi (influenced_by, influenced)
const personSlugs = new Set(personNodes.map((n) => n.data.slug));
const personToPersonEdges: any[] = [];
for (const p of people) {
  const sourceSlug = p.id.replace(/\.md$/, '');
  for (const ib of p.data.influenced_by ?? []) {
    if (personSlugs.has(ib)) {
      personToPersonEdges.push({
        data: {
          id: `e:ib:${ib}->${sourceSlug}`,
          source: `person:${ib}`,
          target: `person:${sourceSlug}`,
          relation: 'influenced',
          kind: 'person2person',
        },
      });
    }
  }
  for (const inf of p.data.influenced ?? []) {
    if (personSlugs.has(inf)) {
      personToPersonEdges.push({
        data: {
          id: `e:in:${sourceSlug}->${inf}`,
          source: `person:${sourceSlug}`,
          target: `person:${inf}`,
          relation: 'influenced',
          kind: 'person2person',
        },
      });
    }
  }
}

// Kitap → kişi (key_people referansları)
const bookToPersonEdges: any[] = [];
for (const b of books) {
  const sourceSlug = b.id.replace(/\.md$/, '');
  for (const kp of b.data.key_people ?? []) {
    if (personSlugs.has(kp.slug)) {
      bookToPersonEdges.push({
        data: {
          id: `e:b2p:${sourceSlug}->${kp.slug}`,
          source: `book:${sourceSlug}`,
          target: `person:${kp.slug}`,
          relation: 'mentions',
          kind: 'book2person',
        },
      });
    }
  }
}

// Tüm graph datası — tek JSON
const graphData = {
  nodes: [...bookNodes, ...personNodes],
  edges: [...bookToBookEdges, ...personToPersonEdges, ...bookToPersonEdges],
};
const graphJson = JSON.stringify(graphData);

const stats = {
  bookCount: bookNodes.length,
  personCount: personNodes.length,
  b2b: bookToBookEdges.length,
  p2p: personToPersonEdges.length,
  b2p: bookToPersonEdges.length,
};
---

<div class="halka-graph-wrapper">
  <div class="halka-graph-meta" role="region" aria-label="Etki ağı lejantı">
    <p class="halka-graph-meta-title">Atomik Atlas — etki ağı katmanı</p>
    <p class="halka-graph-meta-desc">
      <strong>{stats.bookCount} kitap</strong> + <strong>{stats.personCount} kişi</strong>
      düğümü, <strong>{stats.b2b}</strong> kitap-kitap, <strong>{stats.p2p}</strong>
      kişi-kişi ve <strong>{stats.b2p}</strong> kitap-kişi kenarı. Halka cross-ref
      ağının graph-visualizasyonu — "Kim kimden etkilendi?" sorusunun atomik atlas
      cevabı. Düğümlere tıklayın → ilgili sayfaya gidin.
    </p>
    <div class="halka-graph-controls">
      <label class="halka-graph-toggle">
        <input type="checkbox" id="halka-graph-toggle-b2p" checked />
        Kitap-kişi kenarları
      </label>
      <label class="halka-graph-toggle">
        <input type="checkbox" id="halka-graph-toggle-isolated" />
        Yalnız düğümleri sakla
      </label>
      <button id="halka-graph-fit" class="halka-graph-btn" type="button">Görünüme sığdır</button>
    </div>
  </div>

  <div id="halka-influence-graph" class="halka-graph"></div>

  <div class="halka-graph-legend" role="region" aria-label="Düğüm ve kenar rengi açıklaması">
    <div class="halka-graph-legend-section">
      <strong>Düğümler:</strong>
      <span class="halka-graph-legend-item">
        <svg width="14" height="14"><circle cx="7" cy="7" r="6" fill="#0e6b5e" /></svg>
        Kitap (büyüklük = referans-derinliği)
      </span>
      <span class="halka-graph-legend-item">
        <svg width="14" height="14"><circle cx="7" cy="7" r="5" fill="#9c2a3b" /></svg>
        Kişi
      </span>
    </div>
    <div class="halka-graph-legend-section">
      <strong>Kenarlar:</strong>
      <span class="halka-graph-legend-item">
        <svg width="20" height="6"><line x1="0" y1="3" x2="20" y2="3" stroke="#0e6b5e" stroke-width="2" /></svg>
        Kitap-kitap (tematik/tarihyazımı ilişkisi)
      </span>
      <span class="halka-graph-legend-item">
        <svg width="20" height="6"><line x1="0" y1="3" x2="20" y2="3" stroke="#9c2a3b" stroke-width="2" /></svg>
        Kişi-kişi (etkilendi)
      </span>
      <span class="halka-graph-legend-item">
        <svg width="20" height="6"><line x1="0" y1="3" x2="20" y2="3" stroke="#d6cfbb" stroke-width="1.5" stroke-dasharray="3 2" /></svg>
        Kitap-kişi (zikrediyor)
      </span>
    </div>
  </div>
</div>

<script type="application/json" id="halka-graph-json" set:html={graphJson} is:inline></script>

<script
  is:inline
  src="https://unpkg.com/cytoscape@3.30.1/dist/cytoscape.min.js"
></script>

<script is:inline define:vars={{ baseUrl }}>
  function initHalkaGraph() {
    if (typeof cytoscape === 'undefined') {
      setTimeout(initHalkaGraph, 100);
      return;
    }

    const dataEl = document.getElementById('halka-graph-json');
    if (!dataEl) return;
    const data = JSON.parse(dataEl.textContent);

    const cy = cytoscape({
      container: document.getElementById('halka-influence-graph'),
      elements: {
        nodes: data.nodes,
        edges: data.edges,
      },
      style: [
        // Kitap düğümleri
        {
          selector: 'node[type="book"]',
          style: {
            'background-color': '#0e6b5e',
            'border-color': '#191510',
            'border-width': 1.5,
            'label': 'data(label)',
            'color': '#191510',
            'font-family': 'Inter, sans-serif',
            'font-size': 11,
            'font-weight': 600,
            'text-valign': 'bottom',
            'text-margin-y': 6,
            'text-background-color': '#f7f5f0',
            'text-background-opacity': 0.85,
            'text-background-padding': 2,
            'width': 28,
            'height': 28,
          },
        },
        // Kişi düğümleri (büyüklük referans-derinliğine göre)
        {
          selector: 'node[type="person"]',
          style: {
            'background-color': '#9c2a3b',
            'border-color': '#191510',
            'border-width': 1,
            'label': 'data(label)',
            'color': '#191510',
            'font-family': 'Inter, sans-serif',
            'font-size': 9,
            'text-valign': 'bottom',
            'text-margin-y': 4,
            'text-background-color': '#f7f5f0',
            'text-background-opacity': 0.7,
            'text-background-padding': 2,
            'width': 'mapData(refCount, 0, 5, 14, 24)',
            'height': 'mapData(refCount, 0, 5, 14, 24)',
          },
        },
        // Kitap-kitap kenarı
        {
          selector: 'edge[kind="book2book"]',
          style: {
            'width': 1.5,
            'line-color': '#0e6b5e',
            'opacity': 0.55,
            'curve-style': 'bezier',
            'target-arrow-color': '#0e6b5e',
            'target-arrow-shape': 'triangle',
            'arrow-scale': 0.7,
          },
        },
        // Kişi-kişi kenarı
        {
          selector: 'edge[kind="person2person"]',
          style: {
            'width': 1.5,
            'line-color': '#9c2a3b',
            'opacity': 0.6,
            'curve-style': 'bezier',
            'target-arrow-color': '#9c2a3b',
            'target-arrow-shape': 'triangle',
            'arrow-scale': 0.7,
          },
        },
        // Kitap-kişi kenarı (varsayılan görünür)
        {
          selector: 'edge[kind="book2person"]',
          style: {
            'width': 1,
            'line-color': '#d6cfbb',
            'line-style': 'dashed',
            'opacity': 0.45,
            'curve-style': 'bezier',
            'target-arrow-shape': 'none',
          },
        },
        // Hover/seçim
        {
          selector: 'node:active, node:selected',
          style: {
            'border-width': 3,
            'border-color': '#1d8e7a',
          },
        },
        {
          selector: '.faded',
          style: { 'opacity': 0.15 },
        },
      ],
      layout: {
        name: 'cose',
        animate: false,
        idealEdgeLength: 80,
        nodeOverlap: 20,
        refresh: 20,
        fit: true,
        padding: 30,
        randomize: false,
        componentSpacing: 80,
        nodeRepulsion: 4000000,
        edgeElasticity: 100,
        nestingFactor: 5,
        gravity: 80,
        numIter: 1000,
      },
      minZoom: 0.3,
      maxZoom: 3,
      wheelSensitivity: 0.2,
    });

    // Düğüm tıklama → ilgili sayfaya git
    cy.on('tap', 'node', function (evt) {
      const node = evt.target;
      const type = node.data('type');
      const slug = node.data('slug');
      const url = type === 'book'
        ? `${baseUrl}/kitaplar/${slug}`
        : `${baseUrl}/kisiler/${slug}`;
      // Yeni sekmede aç (kullanıcı kontekst kaybını engellesin)
      window.open(url, '_self');
    });

    // Düğüm hover → komşuları vurgula (diğerlerini soldur)
    cy.on('mouseover', 'node', function (evt) {
      const node = evt.target;
      const neighborhood = node.closedNeighborhood();
      cy.elements().not(neighborhood).addClass('faded');
    });
    cy.on('mouseout', 'node', function () {
      cy.elements().removeClass('faded');
    });

    // Toggle: kitap-kişi kenarları
    document.getElementById('halka-graph-toggle-b2p')?.addEventListener('change', (e) => {
      const visible = e.target.checked;
      cy.edges('[kind="book2person"]').style('display', visible ? 'element' : 'none');
    });

    // Toggle: yalnız düğümleri sakla
    document.getElementById('halka-graph-toggle-isolated')?.addEventListener('change', (e) => {
      const hide = e.target.checked;
      const isolated = cy.nodes().filter((n) => n.degree(false) === 0);
      isolated.style('display', hide ? 'none' : 'element');
    });

    // Görünüme sığdır
    document.getElementById('halka-graph-fit')?.addEventListener('click', () => {
      cy.fit(undefined, 30);
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initHalkaGraph);
  } else {
    initHalkaGraph();
  }
</script>

<style>
  .halka-graph-wrapper {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .halka-graph-meta {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 0.85rem;
    padding: 0.75rem 1rem;
    background-color: rgba(255, 255, 255, 0.6);
    border: 1px solid var(--halka-rule);
    border-radius: 2px;
  }
  .halka-graph-meta-title {
    font-weight: 600;
    color: var(--halka-emerald);
    margin: 0 0 0.4rem;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .halka-graph-meta-desc {
    margin: 0 0 0.7rem;
    font-family: 'Crimson Pro', Georgia, serif;
    font-size: 1rem;
    line-height: 1.5;
  }
  .halka-graph-controls {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 1.25rem;
    align-items: center;
    font-size: 0.8rem;
  }
  .halka-graph-toggle {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    cursor: pointer;
  }
  .halka-graph-toggle input { cursor: pointer; }
  .halka-graph-btn {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 0.75rem;
    padding: 0.3rem 0.7rem;
    background-color: var(--halka-emerald);
    color: white;
    border: none;
    border-radius: 2px;
    cursor: pointer;
    transition: background-color 150ms ease;
  }
  .halka-graph-btn:hover {
    background-color: var(--halka-emerald-light);
  }

  .halka-graph {
    height: 640px;
    width: 100%;
    border: 1px solid var(--halka-rule);
    border-radius: 2px;
    background-color: #faf8f3;
  }

  .halka-graph-legend {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 0.78rem;
    color: var(--halka-ink);
    padding: 0.6rem 1rem;
    background-color: rgba(247, 245, 240, 0.6);
    border: 1px solid var(--halka-rule);
    border-radius: 2px;
  }
  .halka-graph-legend-section {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1rem;
    align-items: center;
  }
  .halka-graph-legend-section strong {
    color: var(--halka-emerald);
    font-weight: 600;
    min-width: 5rem;
  }
  .halka-graph-legend-item {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }
  @media (max-width: 640px) {
    .halka-graph { height: 480px; }
  }
</style>
