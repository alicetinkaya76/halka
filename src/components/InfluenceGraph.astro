---
// src/components/InfluenceGraph.astro
//
// Halka v0.18 — Etki Ağı sıfırdan-rewrite.
// =====================================================================
//
// v0.14-v0.17 turlarında Cytoscape.js + CDN-lazy-load + <script type="application/json">
// kombinasyonu kullanıldı. Production GitHub Pages'te canvas-boş-render
// bug-vakası (bkz. v0.18 önhazırlık screenshot) Cytoscape-yüklenme-race-condition
// + Astro static-build JSON-escape kombinasyonundan kaynaklandı. v0.18 turunda
// component sıfırdan modern-D3 v7 force-simulation API'sine yeniden-yazıldı;
// veri-aktarımı `<script type="application/json">` yerine `data-graph-json`
// HTML-attribute'üyle yapılır (Astro static-build escape-güvenli).
//
// Akademik-disiplin-modeli: islamicatlas.org-paralel-yapı.
// (Önhazırlık screenshot'larından türetilmiş yapısal-paralel; bkz. v0.18
//  SONRAKI-OTURUM-PROMPT-v0.18.md §3-A.)
//
//  Yatay-mimari (büyük ekran):
//    +-------------------------------------------------------------+
//    | Üst-bar: title + sayaç + filtreler + arama                  |
//    +---------------------------------------------+---------------+
//    | %75 graf-canvas (force-simulation SVG)      | %25 sağ-panel |
//    |                                             | bağlantı-list |
//    |                                             | scroll        |
//    +---------------------------------------------+---------------+
//    | Lejant + dönem-sürgüsü + akademik-açıklama                  |
//    +-------------------------------------------------------------+
//
//  Filtre-mekanizmaları:
//    - Varlık tipi: Tümü / Kitap / Kişi
//    - Bağlantı türü: Tümü / Kitap-kitap / Kişi-kişi / Kitap-kişi
//    - Dönem-tab'ları: 1./2./3./4. dönem (DONEM_COLORS-paralel renk-kodu)
//    - Search-box: düğüm-adı arama (substring + name_aliases dahil)
//
//  Etkileşim:
//    - Hover-tooltip: kişi → ad+dates+role+ref-count;
//                     kitap → title+author+halka-#+donem+status
//    - Click-to-focus: seçilen-düğüm + komşuları vurgulanır, gerisi soluklaşır
//    - Çift-tık: ilgili-detay-sayfasına git (yeni sekmede)
//    - Sağ-panel-kart-tıklama: ilgili-iki-düğümü vurgular
//
// Mimari ilke: tüm graph-data server-side (build-time) hesaplanır, istemciye
// JSON-attribute'üyle aktarılır; D3 v7 sadece görselleştirme katmanı.

import { getCollection } from 'astro:content';
import { countPersonReferences } from '@/lib/halka-context';
import { curriculum } from '@/lib/curriculum';
import { statusLabels } from '@/lib/labels';

const baseUrl = import.meta.env.BASE_URL;

const books = await getCollection('books');
const people = await getCollection('people');

// --- Dönem-renk-paleti (DONEM_COLORS-paralel; istemcide CSS-var ile uygulanır) ---
// Uyarı: halka-context.ts'deki DONEM_COLORS curriculum.ts'deki uzun-isimleri
// kullanır; ZOD-enum'daki kısa-isimler buradan farklı. Bu yüzden burada
// kısa-isim → renk haritalaması ayrıca kuruyoruz (build-stabil).
const PERIOD_PALETTE: Record<string, { fill: string; label: string; key: string }> = {
  '1. Dönem - Bilim Tarihinin Çerçevesi':
    { fill: '#0e6b5e', label: '1. Dönem · Çerçeve',         key: 'p1' },
  '2. Dönem - Doğu Bilim Geleneği ve İslam Bilimi':
    { fill: '#1d8e7a', label: '2. Dönem · Doğu & İslam',    key: 'p2' },
  '3. Dönem - Batı Bilim Devrimi':
    { fill: '#9c2a3b', label: '3. Dönem · Bilim Devrimi',   key: 'p3' },
  '4. Dönem - Karşılaştırmalı Sentezler':
    { fill: '#5b3a47', label: '4. Dönem · Sentezler',       key: 'p4' },
};
const PERSON_DEFAULT_COLOR = '#7a6a55'; // dönem-bağlamsız kişiler için ink-warm

// --- 1) Düğümler ---

type GraphNode = {
  id: string;
  slug: string;
  label: string;
  type: 'book' | 'person';
  color: string;
  periodKey: string | null;
  refCount: number;
  // Tooltip-zengin alanlar
  title?: string;
  author?: string;
  siraNo?: number;
  donemLabel?: string;
  status?: string;
  dates?: string;
  role?: string;
  aliases?: string[];
};

const bookNodes: GraphNode[] = books.map((b) => {
  const slug = b.id.replace(/\.md$/, '');
  const donem = b.data.halka_metadata.donem;
  const palette = PERIOD_PALETTE[donem];
  return {
    id: `book:${slug}`,
    slug,
    type: 'book',
    label: b.data.author.split(' ').pop() ?? b.data.author,
    color: palette?.fill ?? '#0e6b5e',
    periodKey: palette?.key ?? null,
    refCount: (b.data.relationships_to_other_books ?? []).length,
    title: b.data.title,
    author: b.data.author,
    siraNo: b.data.halka_metadata.sira_no,
    donemLabel: palette?.label ?? donem,
    status: b.data.halka_metadata.status,
  };
});

// Kişi düğümlerinin dönem-türetimi: ilk-referans-eden-kitabın dönemi.
// Bir kişi birden çok dönemde geçiyorsa en-küçük-sıra-no'lu dönem alınır.
function derivePersonPeriod(personSlug: string): { donem: string | null; key: string | null; color: string } {
  let earliestSira = Infinity;
  let donem: string | null = null;
  for (const b of books) {
    if (b.data.key_people?.some((p) => p.slug === personSlug)) {
      const s = b.data.halka_metadata.sira_no;
      if (s < earliestSira) {
        earliestSira = s;
        donem = b.data.halka_metadata.donem;
      }
    }
  }
  if (!donem) return { donem: null, key: null, color: PERSON_DEFAULT_COLOR };
  const palette = PERIOD_PALETTE[donem];
  return { donem, key: palette?.key ?? null, color: palette?.fill ?? PERSON_DEFAULT_COLOR };
}

const personNodes: GraphNode[] = people.map((p) => {
  const slug = p.id.replace(/\.md$/, '');
  const refCount = countPersonReferences(slug, books as any);
  const period = derivePersonPeriod(slug);
  return {
    id: `person:${slug}`,
    slug,
    type: 'person',
    label: p.data.name,
    color: period.color,
    periodKey: period.key,
    refCount,
    dates: p.data.dates ?? '',
    role: p.data.role ?? '',
    donemLabel: period.donem ? PERIOD_PALETTE[period.donem]?.label ?? period.donem : '',
    aliases: p.data.name_aliases ?? [],
  };
});

const allNodes: GraphNode[] = [...bookNodes, ...personNodes];

// --- 2) Kenarlar ---

type GraphEdge = {
  id: string;
  source: string;
  target: string;
  kind: 'book2book' | 'person2person' | 'book2person';
  relation: string;        // ZOD enum-değeri (örn. 'tematik_tamamlayici')
  relationLabel: string;   // İnsan-okunur-Türkçe-etiket (örn. 'Tematik tamamlayıcı')
  // Sağ-panel-bağlantı-listesi için:
  sourceLabel: string;
  targetLabel: string;
  sourceType: 'book' | 'person';
  targetType: 'book' | 'person';
};

// Türkçe-relation-etiket-haritası (ZOD enum → insan-okunur)
const RELATION_LABELS: Record<string, string> = {
  // Kitap-kitap
  kismen_celisir: 'Kısmen çelişir',
  celisir: 'Çelişir',
  uyumlu: 'Uyumlu',
  tematik_tamamlayici: 'Tematik tamamlayıcı',
  teknik_tamamlayici: 'Teknik tamamlayıcı',
  kurumsal_tamamlayici: 'Kurumsal tamamlayıcı',
  olcek_karsitligi: 'Ölçek karşıtlığı',
  ters_yon: 'Ters yön',
  dogrudan_kaynak: 'Doğrudan kaynak',
  cogul_revizyon: 'Çoğul revizyon',
  // Kişi-kişi / Kitap-kişi
  influenced: 'Etkiledi',
  mentions: 'Zikrediyor',
};

const nodeIndex = new Map(allNodes.map((n) => [n.id, n]));

const bookToBookEdges: GraphEdge[] = [];
for (const b of books) {
  const sourceSlug = b.id.replace(/\.md$/, '');
  const sourceId = `book:${sourceSlug}`;
  const sourceNode = nodeIndex.get(sourceId)!;
  for (const rel of b.data.relationships_to_other_books ?? []) {
    const targetId = `book:${rel.book}`;
    const targetNode = nodeIndex.get(targetId);
    if (!targetNode) continue;
    bookToBookEdges.push({
      id: `e:b2b:${sourceSlug}->${rel.book}:${rel.relation}`,
      source: sourceId,
      target: targetId,
      kind: 'book2book',
      relation: rel.relation,
      relationLabel: RELATION_LABELS[rel.relation] ?? rel.relation,
      sourceLabel: `${sourceNode.author} — ${sourceNode.title}`,
      targetLabel: `${targetNode.author} — ${targetNode.title}`,
      sourceType: 'book',
      targetType: 'book',
    });
  }
}

const personSlugs = new Set(personNodes.map((n) => n.slug));
const personToPersonEdges: GraphEdge[] = [];
for (const p of people) {
  const sourceSlug = p.id.replace(/\.md$/, '');
  const sourceId = `person:${sourceSlug}`;
  const sourceNode = nodeIndex.get(sourceId)!;
  for (const ib of p.data.influenced_by ?? []) {
    if (!personSlugs.has(ib)) continue;
    const targetNode = nodeIndex.get(`person:${ib}`);
    if (!targetNode) continue;
    personToPersonEdges.push({
      id: `e:ib:${ib}->${sourceSlug}`,
      source: `person:${ib}`,
      target: sourceId,
      kind: 'person2person',
      relation: 'influenced',
      relationLabel: RELATION_LABELS.influenced,
      sourceLabel: targetNode.label,
      targetLabel: sourceNode.label,
      sourceType: 'person',
      targetType: 'person',
    });
  }
  for (const inf of p.data.influenced ?? []) {
    if (!personSlugs.has(inf)) continue;
    const targetNode = nodeIndex.get(`person:${inf}`);
    if (!targetNode) continue;
    // Çift-yön çakışmasını önle (X→Y zaten varsa ekleme)
    const dupKey = `e:ib:${sourceSlug}->${inf}`;
    if (personToPersonEdges.some((e) => e.id === dupKey)) continue;
    personToPersonEdges.push({
      id: `e:in:${sourceSlug}->${inf}`,
      source: sourceId,
      target: `person:${inf}`,
      kind: 'person2person',
      relation: 'influenced',
      relationLabel: RELATION_LABELS.influenced,
      sourceLabel: sourceNode.label,
      targetLabel: targetNode.label,
      sourceType: 'person',
      targetType: 'person',
    });
  }
}

const bookToPersonEdges: GraphEdge[] = [];
for (const b of books) {
  const sourceSlug = b.id.replace(/\.md$/, '');
  const sourceId = `book:${sourceSlug}`;
  const sourceNode = nodeIndex.get(sourceId)!;
  for (const kp of b.data.key_people ?? []) {
    if (!personSlugs.has(kp.slug)) continue;
    const targetNode = nodeIndex.get(`person:${kp.slug}`);
    if (!targetNode) continue;
    bookToPersonEdges.push({
      id: `e:b2p:${sourceSlug}->${kp.slug}`,
      source: sourceId,
      target: `person:${kp.slug}`,
      kind: 'book2person',
      relation: 'mentions',
      relationLabel: RELATION_LABELS.mentions,
      sourceLabel: `${sourceNode.author} — ${sourceNode.title}`,
      targetLabel: targetNode.label,
      sourceType: 'book',
      targetType: 'person',
    });
  }
}

const allEdges = [...bookToBookEdges, ...personToPersonEdges, ...bookToPersonEdges];

// --- 3) Veri-paketleme ---

const graphData = {
  nodes: allNodes,
  edges: allEdges,
  baseUrl,
};
const graphJson = JSON.stringify(graphData);

const stats = {
  bookCount: bookNodes.length,
  personCount: personNodes.length,
  b2b: bookToBookEdges.length,
  p2p: personToPersonEdges.length,
  b2p: bookToPersonEdges.length,
  totalEdges: allEdges.length,
};

// Donem-tab dökümü (filtre paneli için)
const donemTabs = curriculum
  .filter((d) => d.donem_tipi !== 'ek')
  .map((d, i) => {
    const palette = Object.values(PERIOD_PALETTE)[i];
    return {
      key: palette?.key ?? `p${i + 1}`,
      label: palette?.label ?? d.short,
      color: palette?.fill ?? '#0e6b5e',
    };
  });
---

<div class="ig-wrapper" id="ig-root">
  {/* === Üst-bar: title + sayaç + filtreler + arama ============ */}
  <header class="ig-topbar">
    <div class="ig-topbar-left">
      <p class="ig-eyebrow">Atomik Atlas — Etki Ağı Katmanı</p>
      <p class="ig-counter">
        <span id="ig-edge-counter">{stats.totalEdges}</span>
        <span class="ig-counter-sep"> / </span>
        <span class="ig-counter-total">{stats.totalEdges}</span>
        <span class="ig-counter-label">bağlantı görünür</span>
      </p>
    </div>
    <div class="ig-topbar-right">
      <label class="ig-control">
        <span class="ig-control-label">Varlık Tipi</span>
        <select id="ig-filter-entity" class="ig-select">
          <option value="all">Tümü ({stats.bookCount + stats.personCount})</option>
          <option value="book">Kitap ({stats.bookCount})</option>
          <option value="person">Kişi ({stats.personCount})</option>
        </select>
      </label>
      <label class="ig-control">
        <span class="ig-control-label">Bağlantı Türü</span>
        <select id="ig-filter-edge" class="ig-select">
          <option value="all">Tümü ({stats.totalEdges})</option>
          <option value="book2book">Kitap-kitap ({stats.b2b})</option>
          <option value="person2person">Kişi-kişi ({stats.p2p})</option>
          <option value="book2person">Kitap-kişi ({stats.b2p})</option>
        </select>
      </label>
      <label class="ig-control ig-control-search">
        <span class="ig-control-label">Düğüm Ara</span>
        <input type="search" id="ig-search" class="ig-input" placeholder="örn. Newton, Fara…" autocomplete="off" />
      </label>
    </div>
  </header>

  {/* === Dönem-tab'ları (DONEM_COLORS-paralel) ============ */}
  <div class="ig-period-tabs" role="tablist" aria-label="Dönem-bazlı filtre">
    <button class="ig-period-tab is-active" data-period="all" type="button" role="tab" aria-selected="true">
      Tüm Dönemler
    </button>
    {donemTabs.map((d) => (
      <button
        class="ig-period-tab"
        data-period={d.key}
        type="button"
        role="tab"
        aria-selected="false"
        style={`--ig-tab-color: ${d.color};`}
      >
        {d.label}
      </button>
    ))}
  </div>

  {/* === Ana-alan: 75% graf + 25% sağ-panel ============ */}
  <div class="ig-main">
    <div class="ig-canvas-host" id="ig-canvas-host">
      <svg id="ig-svg" class="ig-svg" role="img" aria-label="Halka etki ağı: kitaplar ve kişiler arası akademik etkilenme grafı">
        {/* SVG içeriği D3 tarafından doldurulur */}
      </svg>
      <div id="ig-tooltip" class="ig-tooltip" role="tooltip" aria-hidden="true"></div>
      <button id="ig-fit" class="ig-fit-btn" type="button" aria-label="Görünüme sığdır">
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M2 6V2h4M14 6V2h-4M2 10v4h4M14 10v4h-4" stroke-linecap="round"/>
        </svg>
        Sığdır
      </button>
      <div id="ig-empty" class="ig-empty" hidden>
        <p>Filtreye uyan düğüm bulunamadı.</p>
      </div>
    </div>

    {/* === Sağ-panel: bağlantı-listesi (akademik-disiplin-zincir) ============ */}
    <aside class="ig-side" aria-label="Bağlantı Listesi">
      <header class="ig-side-header">
        <h2 class="ig-side-title">Bağlantı Listesi</h2>
        <p class="ig-side-sub">
          Kitap-kitap, kişi-kişi ve kitap-kişi akademik-bağlarının atomik-zincir-listesi.
          Bir karta tıklayın → grafda ilgili-iki-düğüm vurgulanır.
        </p>
      </header>
      <ol id="ig-edge-list" class="ig-edge-list" aria-live="polite">
        {/* JS tarafından doldurulur */}
      </ol>
    </aside>
  </div>

  {/* === Lejant + akademik-açıklama (alt) ============ */}
  <footer class="ig-footer">
    <div class="ig-legend">
      <div class="ig-legend-section">
        <span class="ig-legend-title">Düğümler</span>
        <span class="ig-legend-item">
          <svg width="16" height="16" aria-hidden="true"><rect x="2" y="2" width="12" height="12" rx="2" fill="var(--halka-emerald, #0e6b5e)"/></svg>
          Kitap (büyüklük = kitap-kitap-bağ-derinliği)
        </span>
        <span class="ig-legend-item">
          <svg width="16" height="16" aria-hidden="true"><circle cx="8" cy="8" r="5.5" fill="var(--halka-carmine, #9c2a3b)"/></svg>
          Kişi (büyüklük = kitap-referans-derinliği)
        </span>
      </div>
      <div class="ig-legend-section">
        <span class="ig-legend-title">Kenarlar</span>
        <span class="ig-legend-item">
          <svg width="22" height="6" aria-hidden="true"><line x1="0" y1="3" x2="22" y2="3" stroke="var(--halka-emerald, #0e6b5e)" stroke-width="2"/></svg>
          Kitap-kitap
        </span>
        <span class="ig-legend-item">
          <svg width="22" height="6" aria-hidden="true"><line x1="0" y1="3" x2="22" y2="3" stroke="var(--halka-carmine, #9c2a3b)" stroke-width="2"/></svg>
          Kişi-kişi
        </span>
        <span class="ig-legend-item">
          <svg width="22" height="6" aria-hidden="true"><line x1="0" y1="3" x2="22" y2="3" stroke="#b5ad9a" stroke-width="1.5" stroke-dasharray="3 2"/></svg>
          Kitap-kişi
        </span>
      </div>
    </div>
    <p class="ig-foot-note">
      <strong>Pedagojik konum:</strong> Halka'nın "kümülatif bilgi-ağı" tezinin somut göstergesi.
      Bir düğüme <em>tıklayın</em> → komşuları vurgulanır. <em>Çift-tıklayın</em> → ilgili sayfa açılır.
      Sağ-paneldeki bir bağlantı-kartına <em>tıklayın</em> → grafda iki-düğüm-arası-bağ izole edilir.
    </p>
  </footer>

  {/* === Veri-aktarımı: Astro-static-build escape-güvenli ============
       Cytoscape-kullanan v0.14-v0.17 versiyonu <script type="application/json">
       kullanırdı; Astro escape sorunu nedeniyle production'da bozuluyor olabilirdi.
       v0.18 turunda data-attribute kullanıyoruz — daha-güvenli. */}
  <div id="ig-data" data-graph-json={graphJson} hidden></div>
</div>

{/* D3 v7 — CDN-async-yükleme (tek kaynak: jsdelivr-resmi) ============ */}
<script is:inline src="https://cdn.jsdelivr.net/npm/d3@7.9.0/dist/d3.min.js"></script>

<script is:inline>
  // ===================================================================
  // Halka v0.18 — Etki Ağı Client-Side Force-Simulation
  // ===================================================================
  (function () {
    'use strict';

    // -------- Init guard: D3 yüklenmediyse poll-fallback (graceful) --------
    function bootstrap() {
      if (typeof window.d3 === 'undefined') {
        // En fazla 50 deneme (5 saniye) — sonra hata mesajı göster
        if ((bootstrap.attempts = (bootstrap.attempts || 0) + 1) > 50) {
          var host = document.getElementById('ig-canvas-host');
          if (host) host.innerHTML = '<p class="ig-error">D3 kütüphanesi yüklenemedi. Sayfa yenileyin.</p>';
          return;
        }
        return setTimeout(bootstrap, 100);
      }
      try { initInfluenceGraph(); }
      catch (err) {
        console.error('[Halka:InfluenceGraph]', err);
        var host = document.getElementById('ig-canvas-host');
        if (host) host.innerHTML = '<p class="ig-error">Graf başlatılamadı: ' + (err && err.message ? err.message : 'bilinmeyen hata') + '</p>';
      }
    }

    function initInfluenceGraph() {
      var d3 = window.d3;
      var dataEl = document.getElementById('ig-data');
      if (!dataEl) throw new Error('Data div bulunamadı');
      var dataStr = dataEl.getAttribute('data-graph-json');
      if (!dataStr) throw new Error('data-graph-json attribute yok');
      var data = JSON.parse(dataStr);
      var baseUrl = data.baseUrl || '';

      // Mutable copies (D3 force-simulation node-objelerini in-place değiştirir)
      var nodes = data.nodes.map(function (n) { return Object.assign({}, n); });
      var edges = data.edges.map(function (e) { return Object.assign({}, e); });

      var nodeById = new Map();
      nodes.forEach(function (n) { nodeById.set(n.id, n); });

      // -------- SVG mimarisi --------
      var host = document.getElementById('ig-canvas-host');
      var svgEl = document.getElementById('ig-svg');
      var svg = d3.select(svgEl);
      var width = host.clientWidth || 800;
      var height = host.clientHeight || 560;
      svg.attr('viewBox', '0 0 ' + width + ' ' + height)
         .attr('preserveAspectRatio', 'xMidYMid meet');

      // <defs> — ok-uçları (kitap-kitap ve kişi-kişi için yön-göstergesi)
      var defs = svg.append('defs');
      ['arrow-b2b', 'arrow-p2p'].forEach(function (id) {
        defs.append('marker')
          .attr('id', id)
          .attr('viewBox', '0 -5 10 10')
          .attr('refX', 16)
          .attr('refY', 0)
          .attr('markerWidth', 6)
          .attr('markerHeight', 6)
          .attr('orient', 'auto')
          .append('path')
          .attr('d', 'M0,-4L8,0L0,4')
          .attr('fill', id === 'arrow-b2b' ? '#0e6b5e' : '#9c2a3b')
          .attr('opacity', 0.7);
      });

      // SVG ana-katmanlar (zoom-pan için ortak <g>)
      var rootG = svg.append('g').attr('class', 'ig-root-g');
      var edgeG = rootG.append('g').attr('class', 'ig-edges');
      var nodeG = rootG.append('g').attr('class', 'ig-nodes');

      // Zoom-pan
      var zoom = d3.zoom()
        .scaleExtent([0.25, 4])
        .on('zoom', function (ev) { rootG.attr('transform', ev.transform); });
      svg.call(zoom);

      // -------- Ölçek-fonksiyonları --------
      var refMax = Math.max(1, d3.max(nodes, function (n) { return n.refCount; }) || 1);
      function nodeRadius(n) {
        if (n.type === 'book') return 14 + Math.min(n.refCount, 6) * 1.6;
        return 6 + Math.sqrt(Math.max(n.refCount, 0)) * 4;
      }

      // -------- Force-simulation --------
      var sim = d3.forceSimulation(nodes)
        .force('link', d3.forceLink(edges).id(function (n) { return n.id; }).distance(function (e) {
          return e.kind === 'book2person' ? 70 : 110;
        }).strength(function (e) {
          return e.kind === 'book2person' ? 0.25 : 0.55;
        }))
        .force('charge', d3.forceManyBody().strength(-260).distanceMax(420))
        .force('center', d3.forceCenter(width / 2, height / 2).strength(0.06))
        .force('collide', d3.forceCollide().radius(function (n) { return nodeRadius(n) + 6; }))
        .force('x', d3.forceX(width / 2).strength(0.04))
        .force('y', d3.forceY(height / 2).strength(0.04))
        .alphaDecay(0.025);

      // -------- Edge-render --------
      var edgeSel = edgeG.selectAll('line').data(edges, function (d) { return d.id; })
        .enter().append('line')
        .attr('class', function (d) { return 'ig-edge ig-edge-' + d.kind; })
        .attr('data-id', function (d) { return d.id; })
        .attr('data-kind', function (d) { return d.kind; })
        .attr('stroke', function (d) {
          if (d.kind === 'book2book') return '#0e6b5e';
          if (d.kind === 'person2person') return '#9c2a3b';
          return '#b5ad9a';
        })
        .attr('stroke-width', function (d) { return d.kind === 'book2person' ? 1.1 : 1.7; })
        .attr('stroke-dasharray', function (d) { return d.kind === 'book2person' ? '4 3' : ''; })
        .attr('opacity', function (d) { return d.kind === 'book2person' ? 0.45 : 0.6; })
        .attr('marker-end', function (d) {
          if (d.kind === 'book2book') return 'url(#arrow-b2b)';
          if (d.kind === 'person2person') return 'url(#arrow-p2p)';
          return null;
        });

      // -------- Node-render --------
      var nodeSel = nodeG.selectAll('g').data(nodes, function (d) { return d.id; })
        .enter().append('g')
        .attr('class', function (d) { return 'ig-node ig-node-' + d.type; })
        .attr('data-id', function (d) { return d.id; })
        .attr('data-period', function (d) { return d.periodKey || ''; })
        .attr('data-type', function (d) { return d.type; })
        .attr('tabindex', 0)
        .attr('role', 'button')
        .attr('aria-label', function (d) {
          if (d.type === 'book') return d.author + ' — ' + d.title + ' (Halka #' + d.siraNo + ', ' + d.donemLabel + ')';
          return d.label + (d.dates ? ', ' + d.dates : '') + (d.role ? ', ' + d.role : '');
        })
        .call(d3.drag()
          .on('start', function (ev, d) { if (!ev.active) sim.alphaTarget(0.3).restart(); d.fx = d.x; d.fy = d.y; })
          .on('drag',  function (ev, d) { d.fx = ev.x; d.fy = ev.y; })
          .on('end',   function (ev, d) { if (!ev.active) sim.alphaTarget(0); d.fx = null; d.fy = null; }));

      // Kitap düğümleri — yuvarlatılmış-kare; kişi düğümleri — daire
      nodeSel.each(function (d) {
        var g = d3.select(this);
        var r = nodeRadius(d);
        if (d.type === 'book') {
          var s = r * 1.6;
          g.append('rect')
            .attr('x', -s / 2).attr('y', -s / 2).attr('width', s).attr('height', s)
            .attr('rx', 3).attr('ry', 3)
            .attr('fill', d.color)
            .attr('stroke', '#1a1714').attr('stroke-width', 1.2)
            .attr('opacity', 0.92);
          // Halka-no rozet (sıra-numarası)
          g.append('text')
            .attr('class', 'ig-node-num')
            .attr('text-anchor', 'middle').attr('dominant-baseline', 'central')
            .attr('font-size', 10).attr('font-weight', 700).attr('fill', 'white')
            .attr('y', 0).style('pointer-events', 'none')
            .text('#' + d.siraNo);
        } else {
          g.append('circle')
            .attr('r', r)
            .attr('fill', d.color)
            .attr('stroke', '#1a1714').attr('stroke-width', 1)
            .attr('opacity', 0.88);
        }
        // Etiket
        g.append('text')
          .attr('class', 'ig-node-label')
          .attr('text-anchor', 'middle')
          .attr('y', d.type === 'book' ? r * 1.6 / 2 + 13 : r + 11)
          .attr('font-size', d.type === 'book' ? 10.5 : 9.5)
          .attr('font-weight', d.type === 'book' ? 600 : 500)
          .attr('fill', '#1a1714')
          .style('pointer-events', 'none')
          .style('paint-order', 'stroke')
          .style('stroke', 'rgba(247, 245, 240, 0.9)')
          .style('stroke-width', '3px')
          .text(d.label);
      });

      // -------- Tick-handler (kritik: önceki bug-vakasında DOM-attribute-yazımı eksikti) --------
      sim.on('tick', function () {
        edgeSel
          .attr('x1', function (d) { return d.source.x; })
          .attr('y1', function (d) { return d.source.y; })
          .attr('x2', function (d) { return d.target.x; })
          .attr('y2', function (d) { return d.target.y; });
        nodeSel.attr('transform', function (d) { return 'translate(' + d.x + ',' + d.y + ')'; });
      });

      // -------- Tooltip (akademik-zengin) --------
      var tooltip = d3.select('#ig-tooltip');
      function showTooltip(d, ev) {
        var html;
        if (d.type === 'book') {
          html = '<div class="ig-tt-eyebrow">Halka #' + d.siraNo + ' · ' + (d.donemLabel || '') + '</div>'
               + '<div class="ig-tt-title">' + escapeHtml(d.title) + '</div>'
               + '<div class="ig-tt-sub">' + escapeHtml(d.author) + (d.status ? ' · ' + escapeHtml(d.status) : '') + '</div>'
               + '<div class="ig-tt-foot">' + (d.refCount || 0) + ' kitap-kitap bağı</div>';
        } else {
          html = '<div class="ig-tt-eyebrow">Kişi · Halka atomiği</div>'
               + '<div class="ig-tt-title">' + escapeHtml(d.label) + '</div>'
               + (d.dates ? '<div class="ig-tt-sub">' + escapeHtml(d.dates) + '</div>' : '')
               + (d.role ? '<div class="ig-tt-role">' + escapeHtml(truncate(d.role, 130)) + '</div>' : '')
               + '<div class="ig-tt-foot">' + (d.refCount || 0) + ' kitap referansı</div>';
        }
        tooltip.html(html).style('display', 'block').attr('aria-hidden', 'false');
        positionTooltip(ev);
      }
      function positionTooltip(ev) {
        var hostBB = host.getBoundingClientRect();
        var x = ev.clientX - hostBB.left + 14;
        var y = ev.clientY - hostBB.top + 14;
        var ttBB = tooltip.node().getBoundingClientRect();
        if (x + ttBB.width + 12 > host.clientWidth) x = ev.clientX - hostBB.left - ttBB.width - 14;
        if (y + ttBB.height + 12 > host.clientHeight) y = ev.clientY - hostBB.top - ttBB.height - 14;
        tooltip.style('left', x + 'px').style('top', y + 'px');
      }
      function hideTooltip() { tooltip.style('display', 'none').attr('aria-hidden', 'true'); }

      function escapeHtml(s) {
        return String(s).replace(/[&<>"']/g, function (c) {
          return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c];
        });
      }
      function truncate(s, n) { s = String(s); return s.length > n ? s.substring(0, n - 1) + '…' : s; }

      // -------- Click-to-focus (komşu-vurgulama) --------
      var focusedId = null;
      function neighborSet(id) {
        var s = new Set([id]);
        edges.forEach(function (e) {
          var sId = typeof e.source === 'object' ? e.source.id : e.source;
          var tId = typeof e.target === 'object' ? e.target.id : e.target;
          if (sId === id) s.add(tId);
          if (tId === id) s.add(sId);
        });
        return s;
      }
      function applyFocus(id) {
        if (id === null) {
          nodeSel.classed('is-faded', false).classed('is-focused', false);
          edgeSel.classed('is-faded', false).classed('is-focused', false);
          focusedId = null;
          return;
        }
        var nb = neighborSet(id);
        nodeSel.classed('is-focused', function (d) { return d.id === id; })
               .classed('is-faded',   function (d) { return !nb.has(d.id); });
        edgeSel.classed('is-focused', function (d) {
                  var sId = typeof d.source === 'object' ? d.source.id : d.source;
                  var tId = typeof d.target === 'object' ? d.target.id : d.target;
                  return sId === id || tId === id;
               })
               .classed('is-faded', function (d) {
                  var sId = typeof d.source === 'object' ? d.source.id : d.source;
                  var tId = typeof d.target === 'object' ? d.target.id : d.target;
                  return !(sId === id || tId === id);
               });
        focusedId = id;
      }

      nodeSel.on('mouseover', function (ev, d) { showTooltip(d, ev); })
             .on('mousemove', function (ev) { positionTooltip(ev); })
             .on('mouseout',  function () { hideTooltip(); })
             .on('click', function (ev, d) {
                ev.stopPropagation();
                applyFocus(focusedId === d.id ? null : d.id);
             })
             .on('dblclick', function (ev, d) {
                ev.stopPropagation();
                var url = d.type === 'book'
                  ? baseUrl + '/kitaplar/' + d.slug
                  : baseUrl + '/kisiler/' + d.slug;
                window.open(url, '_blank', 'noopener');
             })
             .on('keydown', function (ev, d) {
                if (ev.key === 'Enter' || ev.key === ' ') {
                  ev.preventDefault();
                  applyFocus(focusedId === d.id ? null : d.id);
                }
             });

      svg.on('click', function () { applyFocus(null); });

      // -------- Sağ-panel: bağlantı-listesi --------
      var listEl = document.getElementById('ig-edge-list');
      function renderList(filteredEdges) {
        var html = filteredEdges.map(function (e) {
          var sId = typeof e.source === 'object' ? e.source.id : e.source;
          var tId = typeof e.target === 'object' ? e.target.id : e.target;
          return '<li class="ig-edge-card" data-edge-id="' + escapeHtml(e.id) + '" '
            + 'data-source="' + escapeHtml(sId) + '" '
            + 'data-target="' + escapeHtml(tId) + '" '
            + 'data-kind="' + escapeHtml(e.kind) + '" '
            + 'tabindex="0" role="button">'
            + '<div class="ig-edge-card-head">'
              + '<span class="ig-edge-card-source">' + escapeHtml(truncate(e.sourceLabel, 36)) + '</span>'
              + '<span class="ig-edge-card-arrow" aria-hidden="true">→</span>'
              + '<span class="ig-edge-card-target">' + escapeHtml(truncate(e.targetLabel, 36)) + '</span>'
            + '</div>'
            + '<div class="ig-edge-card-body">'
              + '<span class="ig-edge-card-rel ig-edge-card-rel-' + escapeHtml(e.kind) + '">' + escapeHtml(e.relationLabel) + '</span>'
              + '<span class="ig-edge-card-kind">' + kindLabel(e.kind) + '</span>'
            + '</div>'
          + '</li>';
        }).join('');
        listEl.innerHTML = html;
      }
      function kindLabel(kind) {
        return kind === 'book2book'      ? 'kitap-kitap'
             : kind === 'person2person' ? 'kişi-kişi'
             : 'kitap-kişi';
      }
      renderList(edges);

      // Sağ-panel-kart-tıklama → grafda iki düğümü vurgula
      listEl.addEventListener('click', function (ev) {
        var card = ev.target.closest('.ig-edge-card');
        if (!card) return;
        var sId = card.getAttribute('data-source');
        var tId = card.getAttribute('data-target');
        // İki düğümü focused-set olarak işaretle
        applyFocusPair(sId, tId);
      });
      listEl.addEventListener('keydown', function (ev) {
        if (ev.key !== 'Enter' && ev.key !== ' ') return;
        var card = ev.target.closest('.ig-edge-card');
        if (!card) return;
        ev.preventDefault();
        applyFocusPair(card.getAttribute('data-source'), card.getAttribute('data-target'));
      });
      function applyFocusPair(sId, tId) {
        var pair = new Set([sId, tId]);
        nodeSel.classed('is-focused', function (d) { return pair.has(d.id); })
               .classed('is-faded',   function (d) { return !pair.has(d.id); });
        edgeSel.classed('is-focused', function (d) {
                  var s = typeof d.source === 'object' ? d.source.id : d.source;
                  var t = typeof d.target === 'object' ? d.target.id : d.target;
                  return (s === sId && t === tId) || (s === tId && t === sId);
               })
               .classed('is-faded', function (d) {
                  var s = typeof d.source === 'object' ? d.source.id : d.source;
                  var t = typeof d.target === 'object' ? d.target.id : d.target;
                  return !((s === sId && t === tId) || (s === tId && t === sId));
               });
        focusedId = sId;
      }

      // -------- Filtre-state --------
      var state = {
        entityFilter: 'all',
        edgeFilter: 'all',
        period: 'all',
        search: '',
      };

      function applyFilters() {
        var nodeVisible = new Set();
        // Önce: dönem ve varlık-tipi filtrelerine göre düğüm-görünürlüğü
        nodes.forEach(function (n) {
          var byEntity = state.entityFilter === 'all' || state.entityFilter === n.type;
          var byPeriod = state.period === 'all' || (n.periodKey && n.periodKey === state.period);
          var byTerm = state.search === '' || matchesTerm(n, state.search);
          if (byEntity && byPeriod && byTerm) nodeVisible.add(n.id);
        });

        // Sonra: edge-filter + her iki ucu görünür mü?
        var edgeVisibleCount = 0;
        edgeSel.attr('display', function (e) {
          var sId = typeof e.source === 'object' ? e.source.id : e.source;
          var tId = typeof e.target === 'object' ? e.target.id : e.target;
          var byKind = state.edgeFilter === 'all' || state.edgeFilter === e.kind;
          var endpointsVisible = nodeVisible.has(sId) && nodeVisible.has(tId);
          var visible = byKind && endpointsVisible;
          if (visible) edgeVisibleCount++;
          return visible ? null : 'none';
        });

        nodeSel.attr('display', function (n) { return nodeVisible.has(n.id) ? null : 'none'; });

        // Sayaç güncelle
        document.getElementById('ig-edge-counter').textContent = edgeVisibleCount;

        // Sağ-panel-listesi güncelle
        var visibleEdges = edges.filter(function (e) {
          var sId = typeof e.source === 'object' ? e.source.id : e.source;
          var tId = typeof e.target === 'object' ? e.target.id : e.target;
          var byKind = state.edgeFilter === 'all' || state.edgeFilter === e.kind;
          return byKind && nodeVisible.has(sId) && nodeVisible.has(tId);
        });
        renderList(visibleEdges);

        // Empty-state
        var empty = document.getElementById('ig-empty');
        if (nodeVisible.size === 0) empty.removeAttribute('hidden'); else empty.setAttribute('hidden', '');

        // Simulasyonu yeniden-canlandır (görünür düğümler için)
        sim.alpha(0.3).restart();
      }
      function matchesTerm(n, term) {
        var t = term.toLowerCase();
        if (n.label && n.label.toLowerCase().indexOf(t) !== -1) return true;
        if (n.title && n.title.toLowerCase().indexOf(t) !== -1) return true;
        if (n.author && n.author.toLowerCase().indexOf(t) !== -1) return true;
        if (n.aliases) {
          for (var i = 0; i < n.aliases.length; i++) {
            if (n.aliases[i].toLowerCase().indexOf(t) !== -1) return true;
          }
        }
        return false;
      }

      // -------- UI-bağlamaları --------
      document.getElementById('ig-filter-entity').addEventListener('change', function (e) {
        state.entityFilter = e.target.value; applyFilters();
      });
      document.getElementById('ig-filter-edge').addEventListener('change', function (e) {
        state.edgeFilter = e.target.value; applyFilters();
      });
      var searchInput = document.getElementById('ig-search');
      var searchT;
      searchInput.addEventListener('input', function (e) {
        clearTimeout(searchT);
        searchT = setTimeout(function () {
          state.search = e.target.value.trim();
          applyFilters();
        }, 180);
      });

      // Dönem-tab'ları
      var tabBtns = document.querySelectorAll('.ig-period-tab');
      tabBtns.forEach(function (btn) {
        btn.addEventListener('click', function () {
          tabBtns.forEach(function (b) { b.classList.remove('is-active'); b.setAttribute('aria-selected', 'false'); });
          btn.classList.add('is-active');
          btn.setAttribute('aria-selected', 'true');
          state.period = btn.getAttribute('data-period');
          applyFilters();
        });
      });

      // Sığdır-butonu
      document.getElementById('ig-fit').addEventListener('click', function () {
        // Mevcut görünür düğümlerin bbox'unu hesapla, viewport'a sığdır
        var visible = nodes.filter(function (n) {
          return nodeSel.filter(function (d) { return d.id === n.id; }).attr('display') !== 'none';
        });
        if (visible.length === 0) return;
        var xs = visible.map(function (n) { return n.x; });
        var ys = visible.map(function (n) { return n.y; });
        var x0 = Math.min.apply(null, xs), x1 = Math.max.apply(null, xs);
        var y0 = Math.min.apply(null, ys), y1 = Math.max.apply(null, ys);
        var bw = x1 - x0 + 80, bh = y1 - y0 + 80;
        var k = Math.min(width / bw, height / bh, 2);
        var tx = (width - k * (x0 + x1)) / 2;
        var ty = (height - k * (y0 + y1)) / 2;
        svg.transition().duration(500).call(zoom.transform, d3.zoomIdentity.translate(tx, ty).scale(k));
      });

      // -------- Resize-observer (responsive) --------
      var ro = new ResizeObserver(function () {
        var newW = host.clientWidth, newH = host.clientHeight;
        if (newW > 0 && newH > 0 && (newW !== width || newH !== height)) {
          width = newW; height = newH;
          svg.attr('viewBox', '0 0 ' + width + ' ' + height);
          sim.force('center', d3.forceCenter(width / 2, height / 2).strength(0.06));
          sim.force('x', d3.forceX(width / 2).strength(0.04));
          sim.force('y', d3.forceY(height / 2).strength(0.04));
          sim.alpha(0.3).restart();
        }
      });
      ro.observe(host);
    } // initInfluenceGraph

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', bootstrap);
    } else {
      bootstrap();
    }
  })();
</script>

<style>
  /* ===== Wrapper & layout ===== */
  .ig-wrapper {
    display: flex;
    flex-direction: column;
    gap: 0;
    background: #faf8f3;
    border: 1px solid var(--halka-rule, rgba(26, 23, 20, 0.12));
    border-radius: 4px;
    overflow: hidden;
    font-family: 'Inter', system-ui, sans-serif;
  }

  /* ===== Üst-bar ===== */
  .ig-topbar {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: flex-end;
    gap: 1rem;
    padding: 1rem 1.25rem 0.85rem;
    border-bottom: 1px solid var(--halka-rule, rgba(26, 23, 20, 0.1));
    background: rgba(247, 245, 240, 0.6);
  }
  .ig-topbar-left { min-width: 0; }
  .ig-eyebrow {
    margin: 0;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--halka-emerald, #0e6b5e);
  }
  .ig-counter {
    margin: 0.3rem 0 0;
    font-family: 'Crimson Pro', Georgia, serif;
    font-size: 1.05rem;
    color: var(--halka-ink, #1a1714);
  }
  .ig-counter #ig-edge-counter { font-weight: 700; font-variant-numeric: tabular-nums; }
  .ig-counter-sep { color: rgba(26, 23, 20, 0.35); padding: 0 0.15em; }
  .ig-counter-total { font-variant-numeric: tabular-nums; color: rgba(26, 23, 20, 0.55); }
  .ig-counter-label { margin-left: 0.5em; font-size: 0.85rem; color: rgba(26, 23, 20, 0.55); }

  .ig-topbar-right {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem 1rem;
    align-items: flex-end;
  }
  .ig-control { display: flex; flex-direction: column; gap: 0.2rem; }
  .ig-control-label {
    font-size: 0.66rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: rgba(26, 23, 20, 0.5);
  }
  .ig-select, .ig-input {
    font-family: inherit;
    font-size: 0.82rem;
    padding: 0.32rem 0.55rem;
    border: 1px solid rgba(26, 23, 20, 0.18);
    border-radius: 3px;
    background: white;
    color: var(--halka-ink, #1a1714);
    min-width: 160px;
    line-height: 1.4;
  }
  .ig-select:focus, .ig-input:focus {
    outline: 2px solid var(--halka-emerald, #0e6b5e);
    outline-offset: 1px;
    border-color: transparent;
  }
  .ig-control-search .ig-input { min-width: 180px; }

  /* ===== Dönem-tab'ları ===== */
  .ig-period-tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 0;
    padding: 0.55rem 1.25rem;
    background: rgba(247, 245, 240, 0.4);
    border-bottom: 1px solid var(--halka-rule, rgba(26, 23, 20, 0.08));
  }
  .ig-period-tab {
    --ig-tab-color: rgba(26, 23, 20, 0.4);
    font-family: inherit;
    font-size: 0.78rem;
    font-weight: 500;
    padding: 0.4rem 0.85rem;
    background: transparent;
    color: rgba(26, 23, 20, 0.65);
    border: none;
    border-bottom: 2px solid transparent;
    cursor: pointer;
    transition: color 150ms ease, border-color 150ms ease, background 150ms ease;
    white-space: nowrap;
  }
  .ig-period-tab:hover { color: var(--halka-ink, #1a1714); background: rgba(255, 255, 255, 0.5); }
  .ig-period-tab.is-active {
    color: var(--halka-ink, #1a1714);
    font-weight: 600;
    border-bottom-color: var(--ig-tab-color);
    background: white;
  }
  .ig-period-tab[data-period="all"].is-active {
    border-bottom-color: var(--halka-ink, #1a1714);
  }

  /* ===== Ana-alan: 75-25 split ===== */
  .ig-main {
    display: grid;
    grid-template-columns: minmax(0, 3fr) minmax(280px, 1fr);
    min-height: 580px;
  }
  .ig-canvas-host {
    position: relative;
    background: #faf8f3;
    overflow: hidden;
    height: 580px;
  }
  .ig-svg {
    width: 100%;
    height: 100%;
    display: block;
    cursor: grab;
  }
  .ig-svg:active { cursor: grabbing; }

  .ig-fit-btn {
    position: absolute;
    top: 12px;
    right: 12px;
    display: inline-flex;
