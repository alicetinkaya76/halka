---
// src/pages/index.astro
import BaseLayout from '@/layouts/BaseLayout.astro';
import Halka21Chain from '@/components/Halka21Chain.astro';
import { curriculum } from '@/lib/curriculum';
import { getCollection } from 'astro:content';
import { statusLabels } from '@/lib/labels';
import { getHalkaProgress } from '@/lib/halka-context';

const baseUrl = import.meta.env.BASE_URL;

const allBooks = await getCollection('books');
const builtSlugs = new Set(allBooks.map((b) => b.id.replace(/\.md$/, '')));
const progress = getHalkaProgress();

function statusChipClass(status: string): string {
  switch (status) {
    case 'okunuyor': return 'halka-chip-emerald';
    case 'okundu':   return 'halka-chip';
    case 'sirada':   return 'halka-chip-carmine';
    default:         return 'halka-chip';
  }
}
---

<BaseLayout title="Halka">
  {/* HERO + 21-HALKA ZİNCİRİ */}
  <section class="max-w-6xl mx-auto px-6 pt-12 pb-8">
    <div class="max-w-4xl">
      <h1 class="font-sans text-5xl md:text-6xl font-bold tracking-tight text-ink-900 leading-tight">
        Halka
      </h1>
      <p class="mt-3 text-2xl text-ink-700 font-serif italic">
        Bilim tarihi okuma grubu, halka halka.
      </p>
      <p class="mt-6 max-w-prose text-lg text-ink-700">
        Halka, üniversite öğrencileri ve mezunlarının dört dönemde 21 kitap okuyup
        tartıştığı bir bilim tarihi okuma grubudur. Bu platform, o okumaların
        dijital bedenidir: her kitap bir özet değil, içindeki
        <strong>iddiaların, kişilerin, yerlerin, kavramların ve kaynakların</strong>
        birbirine bağlandığı bir bilgi grafiğidir.
      </p>
    </div>

    {/* 21-halka zinciri — markanın somutlaşması */}
    <div class="mt-10 mb-8">
      <Halka21Chain />
    </div>

    {/* Aksiyon butonları */}
    <div class="mt-6 flex flex-wrap gap-3 font-sans text-sm">
      {progress.current && (
        <a href={`${baseUrl}/kitaplar/${progress.current.slug}`}
           class="inline-flex items-center px-4 py-2 no-underline rounded-sm"
           style="background-color: var(--halka-emerald); color: white;">
          Şu an okunan: {progress.current.author.split(' ').pop()} — {progress.current.title} →
        </a>
      )}
      <a href="#mufredat"
         class="inline-flex items-center px-4 py-2 border no-underline rounded-sm"
         style="border-color: var(--halka-rule); color: var(--halka-ink);">
        Müfredat detay
      </a>
    </div>
  </section>

  {/* 3 YENİ KATMAN — harita / timeline / etki-ağı */}
  <section class="max-w-6xl mx-auto px-6 py-10"
           style="border-top: 1px solid var(--halka-rule); border-bottom: 1px solid var(--halka-rule);">
    <h2 class="font-sans text-2xl font-semibold text-ink-900 mb-2">Atomik Atlasın çoklu pencereleri</h2>
    <p class="text-ink-600 max-w-prose mb-6 font-serif">
      Halka kitap içeriklerini yatay-yönde de okur: aynı atomik düğümleri farklı
      görsel-pedagojik katmanlarda görünür kılar.
    </p>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <a href={`${baseUrl}/harita`} class="halka-layer-card">
        <div class="halka-layer-icon">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="10" r="3"/>
            <path d="M12 2a8 8 0 0 0-8 8c0 1.892.402 3.13 1.5 4.5L12 22l6.5-7.5c1.098-1.37 1.5-2.608 1.5-4.5a8 8 0 0 0-8-8z"/>
          </svg>
        </div>
        <h3 class="halka-layer-title">Coğrafi katman</h3>
        <p class="halka-layer-desc">Türkiye-merkezli dünya haritası. 7 yer-atomiği marker'ı; tıkla, popup'ta detay.</p>
      </a>
      <a href={`${baseUrl}/zaman-cizelgesi`} class="halka-layer-card">
        <div class="halka-layer-icon">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <line x1="3" y1="12" x2="21" y2="12"/>
            <circle cx="6" cy="12" r="2"/>
            <circle cx="12" cy="12" r="2"/>
            <circle cx="18" cy="12" r="2"/>
            <line x1="6" y1="6" x2="6" y2="9"/>
            <line x1="12" y1="15" x2="12" y2="18"/>
            <line x1="18" y1="6" x2="18" y2="9"/>
          </svg>
        </div>
        <h3 class="halka-layer-title">Kronolojik katman</h3>
        <p class="halka-layer-desc">11 kitap ve 13 kişi tek zaman ekseninde. M.Ö. 3000'den günümüze parçalı eksen.</p>
      </a>
      <a href={`${baseUrl}/etki-agi`} class="halka-layer-card">
        <div class="halka-layer-icon">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="6" cy="6" r="2"/>
            <circle cx="18" cy="6" r="2"/>
            <circle cx="12" cy="14" r="2.5"/>
            <circle cx="6" cy="20" r="2"/>
            <circle cx="18" cy="20" r="2"/>
            <line x1="7.5" y1="7.5" x2="10.5" y2="12.5"/>
            <line x1="16.5" y1="7.5" x2="13.5" y2="12.5"/>
            <line x1="10.5" y1="15.5" x2="7.5" y2="18.5"/>
            <line x1="13.5" y1="15.5" x2="16.5" y2="18.5"/>
          </svg>
        </div>
        <h3 class="halka-layer-title">Etki ağı</h3>
        <p class="halka-layer-desc">Cross-ref ilişkilerinin graph-visualizasyonu. "Kim kimden etkilendi?"</p>
      </a>
    </div>
  </section>

  {/* MEVCUT MÜFREDAT GRİDİ — korunur */}
  <section id="mufredat" class="max-w-6xl mx-auto px-6 py-12">
    <h2 class="font-sans text-3xl font-semibold text-ink-900 mb-2">Müfredat detay</h2>
    <p class="text-ink-600 max-w-prose mb-10 font-serif">
      Dört dönem, 21 kitap. Geçmişte okunanlar geriye dönük doldurulur; sırada
      bekleyenler okundukça şablonu zenginleşir.
    </p>

    <div class="space-y-12">
      {curriculum.map((d) => (
        <div>
          <header class="mb-5 pb-3 halka-rule">
            <h3 class="font-sans text-2xl font-semibold text-ink-900">{d.donem}</h3>
            <p class="mt-1 text-ink-600 font-serif">{d.description}</p>
          </header>

          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {d.books.map((b) => {
              const isBuilt = builtSlugs.has(b.slug);
              const href = isBuilt ? `${baseUrl}/kitaplar/${b.slug}` : '#';
              const Tag = isBuilt ? 'a' : 'div';
              return (
                <Tag
                  href={isBuilt ? href : undefined}
                  class={`halka-card ${isBuilt ? '' : 'opacity-70 cursor-not-allowed'}`}
                  style={isBuilt ? '' : 'pointer-events: none;'}
                >
                  <div class="flex items-start justify-between gap-3 mb-2">
                    <span class="font-sans text-xs font-semibold text-ink-400">#{b.sira_no}</span>
                    <span class={statusChipClass(b.status)}>{statusLabels[b.status]}</span>
                  </div>
                  <h4 class="font-sans text-lg font-semibold leading-tight text-ink-900">
                    {b.title}
                  </h4>
                  <p class="mt-1 text-sm text-ink-600 font-serif italic">{b.author}</p>
                  {!isBuilt && (
                    <p class="mt-3 text-xs text-ink-400 font-sans">İçerik henüz oluşturulmadı</p>
                  )}
                </Tag>
              );
            })}
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="max-w-4xl mx-auto px-6 py-12">
    <h2 class="font-sans text-3xl font-semibold text-ink-900 mb-4">Halka neyi farklı yapar?</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 font-serif">
      <div>
        <h3 class="font-sans text-base font-semibold text-emerald mb-2">Bilgi grafiği</h3>
        <p class="text-ink-700">
          Her kitap atomik birimlere ayrılır: iddialar, kişiler, yerler, kavramlar.
          Bu birimler kitap sınırlarını aşarak birbirine bağlanır.
        </p>
      </div>
      <div>
        <h3 class="font-sans text-base font-semibold text-emerald mb-2">Tarihyazımı görünür</h3>
        <p class="text-ink-700">
          Her yazarın hangi gelenekten konuştuğu — Eurocentric mi anti-Eurocentric mi,
          içselci mi dışsalcı mı — birinci sınıf bilgi olarak işlenir.
        </p>
      </div>
      <div>
        <h3 class="font-sans text-base font-semibold text-emerald mb-2">DH altyapısına bağlı</h3>
        <p class="text-ink-700">
          Geçen kişiler tabakat.io'ya, mekânlar islamicatlas.org'a, eserler GAS'a,
          kavramlar DİA'ya — profesyonel dijital beşeri bilimler ekosistemine köprülenir.
        </p>
      </div>
    </div>
  </section>

  <style>
    .halka-layer-card {
      display: block;
      padding: 1.25rem 1.25rem 1.5rem;
      background-color: white;
      border: 1px solid var(--halka-rule);
      border-radius: 2px;
      text-decoration: none;
      transition: box-shadow 200ms ease, transform 200ms ease, border-color 200ms ease;
    }
    .halka-layer-card:hover {
      box-shadow: 0 4px 16px rgba(25, 21, 16, 0.08);
      transform: translateY(-2px);
      border-color: var(--halka-emerald);
    }
    .halka-layer-icon {
      color: var(--halka-emerald);
      margin-bottom: 0.6rem;
    }
    .halka-layer-title {
      font-family: 'Inter', system-ui, sans-serif;
      font-size: 1.1rem;
      font-weight: 600;
      color: var(--halka-ink);
      margin: 0 0 0.4rem;
    }
    .halka-layer-desc {
      font-family: 'Crimson Pro', Georgia, serif;
      font-size: 0.95rem;
      color: var(--halka-ink);
      opacity: 0.78;
      line-height: 1.45;
      margin: 0;
    }
  </style>
</BaseLayout>
