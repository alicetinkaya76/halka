---
// src/pages/programlar.astro
// Halka Türkiye umbrella-mimarisinin akademik-disiplin-sunum-sayfası.
// v0.19'da eklendi.

import BaseLayout from '@/layouts/BaseLayout.astro';
import {
  programs,
  getActiveProgram,
  getSisterPrograms,
  groupByKademe,
} from '@/lib/programs';

const baseUrl = import.meta.env.BASE_URL;
const active = getActiveProgram();
const sisters = getSisterPrograms();

const KADEME_LABELS: Record<number, string> = {
  1: 'Akademik-başlangıç-kademe',
  2: 'Akademik-orta-kademe',
  3: 'Akademik-derinleşme-kademe',
  4: 'Akademik-zenith-kademe',
};
---

<BaseLayout
  title="Programlar"
  description="Halka Türkiye umbrella'sının dört aktif okuma-programı: Doğu'dan Batı'ya Bilimin Yolculuğu, İdeolojiler ve Toplumsal Devrimler, 40 Eserde İslam Düşüncesi, Riyâzu's-Sâlihîn."
>
  {/* HERO */}
  <section class="max-w-5xl mx-auto px-6 pt-12 pb-10">
    <div class="flex items-baseline gap-3 mb-1">
      <span class="font-sans text-xs uppercase tracking-wider text-emerald font-semibold">
        Halka Türkiye
      </span>
      <span class="text-ink-300 font-sans text-xs">·</span>
      <span class="font-sans text-xs text-ink-500">Umbrella mimarisi</span>
    </div>
    <h1 class="font-sans text-4xl md:text-5xl font-bold tracking-tight text-ink-900 leading-tight">
      Halka Türkiye Programları
    </h1>
    <p class="mt-4 max-w-prose text-lg text-ink-700 font-serif leading-relaxed">
      Halka, Türkiye'de okuma-grubu-tematik-kategorilerinin akademik-disiplinli
      umbrella-markasıdır. Her bir program <em>"Halka: [Program Adı]"</em>
      formatında akademik-isimlemede konumlanır ve umbrella'nın kardeş-program-akademik-zincir-yapısının
      somut-vakası olarak okunur. Şu anda dört aktif okuma-programı vardır;
      <strong>bu site</strong> onlardan biri olan
      <em>"Doğu'dan Batı'ya Bilimin Yolculuğu"</em>'nun dijital atlasını barındırır.
    </p>
  </section>

  {/* AKTİF PROGRAM — BU SİTE */}
  <section class="max-w-5xl mx-auto px-6 pb-10">
    <div class="halka-card relative">
      <div class="absolute -top-3 left-6">
        <span
          class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-sm text-xs font-sans font-semibold tracking-wide"
          style="background-color: var(--halka-emerald); color: white;"
        >
          <svg width="10" height="10" viewBox="0 0 12 12" fill="currentColor" aria-hidden="true">
            <circle cx="6" cy="6" r="3" />
          </svg>
          Bu site · aktif program
        </span>
      </div>
      <div class="pt-3">
        <h2 class="font-sans text-2xl font-semibold text-ink-900 leading-tight">
          {active.full_name}
        </h2>
        <p class="mt-2 text-sm text-emerald font-sans">
          {active.thematic_axis}
        </p>
        <p class="mt-4 text-ink-700 font-serif leading-relaxed">
          {active.description}
        </p>
        {active.notes && (
          <p class="mt-3 text-sm text-ink-500 font-serif italic">
            {active.notes}
          </p>
        )}
        <div class="mt-5 flex flex-wrap gap-2 font-sans text-sm">
          <a
            href={`${baseUrl}/#mufredat`}
            class="inline-flex items-center px-4 py-2 no-underline rounded-sm"
            style="background-color: var(--halka-emerald); color: white;"
          >
            Müfredatı gör →
          </a>
          <a
            href={baseUrl}
            class="inline-flex items-center px-4 py-2 border no-underline rounded-sm"
            style="border-color: var(--halka-rule); color: var(--halka-ink);"
          >
            Atomik atlasa dön
          </a>
        </div>
      </div>
    </div>
  </section>

  {/* KARDEŞ PROGRAMLAR */}
  <section class="max-w-5xl mx-auto px-6 pb-12">
    <header class="mb-6 pb-3 halka-rule">
      <h2 class="font-sans text-2xl font-semibold text-ink-900">Kardeş programlar</h2>
      <p class="mt-1 text-ink-600 font-serif">
        Halka Türkiye umbrella'sındaki diğer üç akademik-okuma-programı —
        akademik-disiplin-konumlaması bağımsız, ama her biri kardeş-akademik-zincirlerle
        yapısal-paralel-akademik-tartışma-zemini açar.
      </p>
    </header>

    <div class="space-y-6">
      {sisters.map((p) => {
        const grouped = p.has_kademe_structure ? groupByKademe(p.reading_list) : null;
        return (
          <article class="halka-card">
            <h3 class="font-sans text-xl font-semibold text-ink-900 leading-tight">
              {p.full_name}
            </h3>
            <p class="mt-1.5 text-sm text-emerald font-sans">{p.thematic_axis}</p>
            <p class="mt-3 text-ink-700 font-serif leading-relaxed">{p.description}</p>

            {/* Müfredat — collapsible */}
            <details class="mt-4 group">
              <summary class="cursor-pointer font-sans text-sm font-semibold text-ink-700 hover:text-emerald flex items-center gap-1.5 list-none">
                <svg
                  width="12"
                  height="12"
                  viewBox="0 0 12 12"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="transition-transform group-open:rotate-90"
                  aria-hidden="true"
                >
                  <polyline points="4 2 8 6 4 10"></polyline>
                </svg>
                <span>
                  Müfredat
                  {p.has_kademe_structure
                    ? ` — ${p.reading_list.length} eser, 4 kademe`
                    : ` — ${p.reading_list.length} kitap`}
                </span>
              </summary>

              {/* Kademe-yapısı varsa */}
              {grouped ? (
                <div class="mt-4 space-y-5">
                  {[1, 2, 3, 4].map((k) => (
                    <div>
                      <h4 class="font-sans text-xs font-semibold tracking-wider uppercase text-ink-500 mb-2">
                        {k}. Kademe — {KADEME_LABELS[k]}
                      </h4>
                      <ol class="space-y-1.5 font-serif text-sm text-ink-700 ml-1">
                        {grouped[k].map((item, idx) => (
                          <li class="flex items-baseline gap-2">
                            <span class="font-sans text-xs text-ink-400 w-5 shrink-0 tabular-nums">
                              {idx + 1}.
                            </span>
                            <span>
                              <em class="not-italic font-medium">{item.title}</em>
                              <span class="text-ink-500"> — {item.author}</span>
                            </span>
                          </li>
                        ))}
                      </ol>
                    </div>
                  ))}
                </div>
              ) : (
                <ol class="mt-4 space-y-1.5 font-serif text-sm text-ink-700">
                  {p.reading_list.map((item, idx) => (
                    <li class="flex items-baseline gap-2">
                      <span class="font-sans text-xs text-ink-400 w-5 shrink-0 tabular-nums">
                        {idx + 1}.
                      </span>
                      <span>
                        <em class="not-italic font-medium">{item.title}</em>
                        <span class="text-ink-500"> — {item.author}</span>
                      </span>
                    </li>
                  ))}
                </ol>
              )}
            </details>

            {/* Cross-program akademik-zincir-konumlaması */}
            {p.cross_program_links && p.cross_program_links.length > 0 && (
              <details class="mt-3 group">
                <summary class="cursor-pointer font-sans text-sm font-semibold text-ink-700 hover:text-emerald flex items-center gap-1.5 list-none">
                  <svg
                    width="12"
                    height="12"
                    viewBox="0 0 12 12"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="transition-transform group-open:rotate-90"
                    aria-hidden="true"
                  >
                    <polyline points="4 2 8 6 4 10"></polyline>
                  </svg>
                  <span>
                    Bilim Tarihi programıyla akademik-zincir-konumlaması
                    <span class="text-ink-400"> — {p.cross_program_links.length}</span>
                  </span>
                </summary>
                <div class="mt-3 space-y-3">
                  {p.cross_program_links.map((link) => (
                    <div
                      class="border-l-2 pl-3 py-1"
                      style="border-color: var(--halka-emerald);"
                    >
                      <p class="text-xs font-sans font-semibold text-ink-700">
                        {link.this_site_anchor}
                        <span class="text-ink-400 mx-1.5">↔</span>
                        <span class="text-ink-600 font-normal">
                          {link.sister_program_item}
                        </span>
                      </p>
                      <p class="mt-1 text-xs text-ink-600 font-serif leading-snug">
                        {link.thematic_axis}
                      </p>
                    </div>
                  ))}
                </div>
              </details>
            )}

            {p.notes && (
              <p class="mt-4 text-xs text-ink-500 font-serif italic">{p.notes}</p>
            )}
          </article>
        );
      })}
    </div>
  </section>

  {/* YAPI NOTU */}
  <section class="max-w-4xl mx-auto px-6 py-10">
    <div
      class="border-l-2 pl-5 py-2 font-serif text-ink-700"
      style="border-color: var(--halka-rule);"
    >
      <p class="text-sm">
        <strong class="font-sans">Akademik-disiplin-not:</strong> Cross-program
        akademik-zincir-cross-ref'leri v0.19'da yalnızca bu sayfanın akademik-disiplin-paragraflarında
        ve ilgili-mevcut-atomiklerde (örn. <a
          href={`${baseUrl}/yerler/sam`}
          class="text-emerald hover:underline"
        >places/sam</a> — Riyâzu's-Sâlihîn-İmam-Nevevî yapısal-paralel) işaret edilir.
        Tam-cross-program-cross-ref-mekanizması (atomik atlas zemininde tamamlanmış-yapısal-aktivasyon)
        v0.20+ turlarına bırakılmıştır.
      </p>
    </div>
  </section>

  <style>
    /* details/summary marker'ını gizle (özel ikonu kullanıyoruz) */
    details summary::-webkit-details-marker {
      display: none;
    }
    details summary::marker {
      content: '';
    }
  </style>
</BaseLayout>
